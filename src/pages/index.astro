---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lily House Montessori Schools — Cape Town" description="Montessori Schools in Cape Town with three campuses in Claremont, Durbanville, and Melkbos.">
  <!-- HERO -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-text">
          <span class="badge">✦ Montessori Certified Since 2020</span>
          <h1>Unlock Your<br />Child's Potential</h1>
          <p>We believe every child has unique talents and abilities waiting to be discovered. Our Montessori approach nurtures curiosity, independence, and confidence.</p>
          <div class="hero-btns">
            <a href="/contact" class="btn btn-yellow">Book a Tour</a>
            <a href="/admissions" class="btn btn-play">
              <span class="play-icon">▶</span> Enroll Now
            </a>
          </div>
        </div>
        <div class="hero-photos">
          <div class="photo-grid">
            <div class="photo-item p1"><img src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Lily-House-14.jpg?w=400&ssl=1" alt="" loading="eager" /></div>
            <div class="photo-item p2"><img src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/02/Lily-House-104-scaled.jpg?w=400&ssl=1" alt="" loading="eager" /></div>
            <div class="photo-item p3"><img src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Lily-House-12.jpg?w=400&ssl=1" alt="" loading="eager" /></div>
            <div class="photo-item p4"><img src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Jaxon_B_Candid-1.jpg?w=400&ssl=1" alt="" loading="eager" /></div>
          </div>
        </div>
      </div>
    </div>
    <!-- Decorative elements -->
    <div class="deco-circle deco-yellow"></div>
    <div class="deco-circle deco-teal"></div>
    <div class="deco-circle deco-dot"></div>
    <div class="deco-lines">
      <svg viewBox="0 0 200 100" fill="none"><path d="M0 50 Q50 0 100 50 Q150 100 200 50" stroke="#E5E7EB" stroke-width="2" fill="none"/></svg>
    </div>
  </section>

  <!-- WHY CHOOSE US -->
  <section class="section-why">
    <div class="container">
      <div class="section-head">
        <span class="label">Why Choose Us</span>
        <h2>Experience the Magic of Montessori</h2>
      </div>
      <div class="photo-row">
        <div class="arch-card"><img src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Lily-House-14.jpg?w=400&ssl=1" alt="" loading="lazy" /></div>
        <div class="arch-card"><img src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/02/Lily-House-104-scaled.jpg?w=400&ssl=1" alt="" loading="lazy" /></div>
        <div class="arch-card"><img src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Lily-House-12.jpg?w=400&ssl=1" alt="" loading="lazy" /></div>
        <div class="arch-card"><img src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Jaxon_B_Candid-1.jpg?w=400&ssl=1" alt="" loading="lazy" /></div>
      </div>
    </div>
  </section>

  <!-- CAMPUSES -->
  <section class="section" id="campuses">
    <div class="container">
      <div class="section-head">
        <span class="label">Our Campuses</span>
        <h2>Find Your Campus</h2>
        <p style="color:var(--text-light);margin-top:0.5rem;">Three unique locations across Cape Town.</p>
      </div>
      <div class="campus-row">
        <a href="/contact#claremont" class="campus-card">
          <div class="campus-card-img"><img src="https://images.unsplash.com/photo-1580582932707-520aed937b7b?w=600&q=80" alt="Claremont" loading="lazy" /></div>
          <div class="campus-card-body">
            <h3>Claremont</h3>
            <p>Queen Victoria Road, Southern Suburbs</p>
            <span>Explore →</span>
          </div>
        </a>
        <a href="/contact#durbanville" class="campus-card">
          <div class="campus-card-img"><img src="https://images.unsplash.com/photo-1571260899304-425eee4c7efc?w=600&q=80" alt="Durbanville" loading="lazy" /></div>
          <div class="campus-card-body">
            <h3>Durbanville</h3>
            <p>Hooggelegen Road, Durbanville Valley</p>
            <span>Explore →</span>
          </div>
        </a>
        <a href="/contact#melkbos" class="campus-card">
          <div class="campus-card-img"><img src="https://images.unsplash.com/photo-1503454537195-1dcabb73ffb9?w=600&q=80" alt="Melkbos" loading="lazy" /></div>
          <div class="campus-card-body">
            <h3>Melkbos</h3>
            <p>Charles Hoffe Avenue, West Coast</p>
            <span>Explore →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-cream" style="padding:5rem 0;">
    <div class="container">
      <div style="text-align:center;max-width:600px;margin:0 auto;">
        <span class="label">Get Started</span>
        <h2 style="font-size:2rem;font-weight:800;margin-bottom:1rem;">Start Your Child's Adventure</h2>
        <p style="color:var(--text-light);margin-bottom:2rem;">Give your child the gift of a Montessori education. Book a tour today.</p>
        <a href="/contact" class="btn btn-yellow" style="padding:0.85rem 2.5rem;font-size:1.05rem;">Book a Visit</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* === HERO === */
  .hero-section {
    padding: 3rem 0;
    background: linear-gradient(180deg, #F8FAFC 0%, #FFFFFF 100%);
    position: relative;
    overflow: hidden;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  /* Hero text */
  .badge {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--teal);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 1rem;
    background: var(--teal-light);
    padding: 0.35rem 0.9rem;
    border-radius: 2rem;
  }
  .hero-text h1 {
    font-size: 3rem;
    font-weight: 900;
    color: var(--text);
    line-height: 1.05;
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
  }
  .hero-text p {
    font-size: 1.1rem;
    color: #6B7280;
    line-height: 1.7;
    margin-bottom: 2rem;
  }
  .hero-btns {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .btn-yellow {
    background: #FBBF24;
    color: #1F2937;
    font-weight: 700;
    padding: 0.85rem 2rem;
    border-radius: 2rem;
    font-size: 1rem;
    border: none;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .btn-yellow:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(251,191,36,0.3); }
  .btn-play {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 700;
    font-size: 1rem;
    color: var(--teal);
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    transition: color 0.2s;
  }
  .btn-play:hover { color: var(--teal-dark); }
  .play-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px; height: 40px;
    border-radius: 50%;
    background: var(--teal);
    color: white;
    font-size: 0.8rem;
    transition: transform 0.2s;
  }
  .btn-play:hover .play-icon { transform: scale(1.1); }

  /* Photo grid - 2x2 square */
  .photo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  .photo-item {
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  }
  .photo-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    aspect-ratio: 1;
  }
  .p2 { margin-top: 2rem; }
  .p3 { margin-bottom: 2rem; }

  /* Decorative elements */
  .deco-circle {
    position: absolute;
    border-radius: 50%;
    z-index: 0;
    pointer-events: none;
  }
  .deco-yellow {
    width: 280px; height: 280px;
    background: rgba(251,191,36,0.15);
    top: 10%; right: 15%;
  }
  .deco-teal {
    width: 120px; height: 120px;
    background: rgba(0,114,154,0.08);
    bottom: 15%; right: 5%;
  }
  .deco-dot {
    width: 16px; height: 16px;
    background: #8B5CF6;
    opacity: 0.3;
    bottom: 30%; right: 30%;
  }
  .deco-lines {
    position: absolute;
    top: 5%; right: 5%;
    width: 200px; height: 100px;
    z-index: 0;
    pointer-events: none;
    opacity: 0.5;
  }
  .deco-lines svg { width: 100%; height: 100%; }

  /* === WHY CHOOSE US === */
  .section-why { padding: 5rem 0; background: #FFFFFF; }
  .section-head {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 3rem;
  }
  .label {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--teal);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.5rem;
  }
  .section-head h2 {
    font-size: 2rem;
    font-weight: 800;
    color: var(--text);
  }

  .photo-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .arch-card {
    border-radius: 5rem 5rem 1rem 1rem;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  }
  .arch-card img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
  }

  /* === CAMPUSES === */
  .campus-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .campus-card {
    display: flex;
    flex-direction: column;
    border-radius: 1rem;
    overflow: hidden;
    background: white;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .campus-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.1); }
  .campus-card-img { height: 200px; overflow: hidden; }
  .campus-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
  .campus-card:hover .campus-card-img img { transform: scale(1.05); }
  .campus-card-body { padding: 1.25rem; flex: 1; }
  .campus-card-body h3 { font-size: 1.15rem; font-weight: 700; margin-bottom: 0.25rem; color: var(--teal); }
  .campus-card-body p { font-size: 0.85rem; color: var(--text-light); }
  .campus-card-body span { font-weight: 600; font-size: 0.85rem; color: var(--teal); display: inline-block; margin-top: 0.5rem; }

  /* === MOBILE === */
  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 2rem; }
    .hero-text h1 { font-size: 2rem; }
    .hero-text p { font-size: 1rem; max-width: 100%; }
    .hero-section { padding: 3rem 0; }
    .photo-grid { gap: 0.5rem; }
    .p2 { margin-top: 1rem; }
    .p3 { margin-bottom: 1rem; }
    .photo-row { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    .campus-row { grid-template-columns: 1fr; }
    .deco-yellow { width: 150px; height: 150px; top: 5%; right: 5%; }
    .deco-lines { display: none; }
  }
</style>
