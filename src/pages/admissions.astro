---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Admissions — Lily House Montessori Schools" description="Enroll at Lily House Montessori Schools. View fees, book a tour, and apply online for our Claremont, Durbanville, and Melkbos campuses.">
  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <h1>Admissions</h1>
      <p class="subtitle">Start Your Child's Journey at Lily House</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="section">
    <div class="container">
      <div style="max-width:700px;margin:0 auto;text-align:center;">
        <p style="font-size:1.1rem;color:var(--text-light);line-height:1.7;">
          We are so glad you're here. We've made our admissions process simple and straightforward. 
          Find all the information you need to enroll your child below.
        </p>
      </div>
    </div>
  </section>

  <!-- Enrollment Process -->
  <section class="section section-alt" style="padding-top:0;">
    <div class="container">
      <h2 class="section-title">Our Enrolment Process</h2>
      <div class="grid-3">
        <div class="step">
          <div class="step-number">1</div>
          <h3>Book a Tour</h3>
          <p style="color:var(--text-light);">We invite you to visit a campus, meet our team, and see our Montessori philosophy in action.</p>
        </div>
        <div class="step">
          <div class="step-number">2</div>
          <h3>Apply Online</h3>
          <p style="color:var(--text-light);">Complete our simple online application form below. This will begin the official enrollment process.</p>
        </div>
        <div class="step">
          <div class="step-number">3</div>
          <h3>Welcome to Lily House</h3>
          <p style="color:var(--text-light);">Once your application is received, our team will contact you to confirm enrollment and welcome your family.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Fee Tables -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Pricing &amp; Fees</h2>
      <p class="text-center" style="color:var(--text-light);margin-top:-2rem;margin-bottom:2rem;">We believe in providing clear, all-inclusive fee structures.</p>

      <div style="margin-bottom:3rem;">
        <h3 style="font-size:1.4rem;margin-bottom:1rem;color:var(--teal);">Claremont Fees 2026</h3>
        <div style="overflow-x:auto;">
          <table class="fee-table">
            <thead>
              <tr>
                <th>Programme</th>
                <th>Fee</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Toddler (18-36 months) — Half Day (07:30-12:30)</td>
                <td class="fee-amount">R4,190<span style="font-weight:400;color:var(--text-light);"> /month</span></td>
              </tr>
              <tr>
                <td>Toddler (18-36 months) — Full Day (07:30-17:00)</td>
                <td class="fee-amount">R5,270<span style="font-weight:400;color:var(--text-light);"> /month</span></td>
              </tr>
              <tr>
                <td colspan="2" style="font-size:0.8rem;color:var(--text-light);"><strong>Annual Resource Fee:</strong> R1,500</td>
              </tr>
            </tbody>
          </table>
        </div>
        <h4 style="margin-top:1.5rem;margin-bottom:0.5rem;font-size:1rem;">Optional Extras</h4>
        <div style="overflow-x:auto;">
          <table class="fee-table">
            <thead>
              <tr>
                <th>Extra</th>
                <th>Cost</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>Aftercare (ad hoc, daily)</td><td class="fee-amount">R90<span style="font-weight:400;color:var(--text-light);"> /day</span></td></tr>
              <tr><td>Lunch (monthly)</td><td class="fee-amount">R550<span style="font-weight:400;color:var(--text-light);"> /month</span></td></tr>
              <tr><td>Holiday Club — Half Day</td><td class="fee-amount">R170<span style="font-weight:400;color:var(--text-light);"> /day</span></td></tr>
              <tr><td>Holiday Club — Full Day</td><td class="fee-amount">R240<span style="font-weight:400;color:var(--text-light);"> /day</span></td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Durbanville -->
      <div style="margin-bottom:3rem;">
        <h3 style="font-size:1.4rem;margin-bottom:1rem;color:var(--teal);">Durbanville Campus</h3>
        <p style="color:var(--text-light);">Please contact the Durbanville campus directly for the latest fee schedule.</p>
        <a href="/contact#durbanville" class="btn btn-teal" style="margin-top:0.5rem;display:inline-block;">Contact Durbanville</a>
      </div>

      <!-- Melkbos -->
      <div>
        <h3 style="font-size:1.4rem;margin-bottom:1rem;color:var(--teal);">Melkbos Campus</h3>
        <p style="color:var(--text-light);">Please contact the Melkbos campus directly for the latest fee schedule.</p>
        <a href="/contact#melkbos" class="btn btn-teal" style="margin-top:0.5rem;display:inline-block;">Contact Melkbos</a>
      </div>
    </div>
  </section>

  <!-- Enrollment Form -->
  <section class="section section-alt">
    <div class="container">
      <div style="max-width:700px;margin:0 auto;">
        <h2 class="section-title">Enroll Now</h2>
        <p style="text-align:center;color:var(--text-light);margin-bottom:2rem;">
          Please complete the form below to begin the enrollment process. A copy will be automatically routed to our admissions team for review.
        </p>
        <form action="#" method="POST" style="background:var(--white);padding:2rem;border-radius:var(--radius);">
          <div class="form-group">
            <label for="parent-name">Parent's Full Name <span style="color:red;">*</span></label>
            <input type="text" id="parent-name" name="parent-name" required />
          </div>
          <div class="form-group">
            <label for="child-name">Child's Full Name <span style="color:red;">*</span></label>
            <input type="text" id="child-name" name="child-name" required />
          </div>
          <div class="form-group">
            <label for="email">Parent's Email <span style="color:red;">*</span></label>
            <input type="email" id="email" name="email" required />
          </div>
          <div class="form-group">
            <label for="phone">Parent's Number <span style="color:red;">*</span></label>
            <input type="tel" id="phone" name="phone" required />
          </div>
          <div class="form-group">
            <label for="dob">Child's Date of Birth <span style="color:red;">*</span></label>
            <input type="date" id="dob" name="dob" required />
          </div>
          <div class="form-group">
            <label>Choose Your Campus <span style="color:red;">*</span></label>
            <div class="radio-group">
              <label><input type="radio" name="campus" value="claremont" required /> Claremont</label>
              <label><input type="radio" name="campus" value="durbanville" /> Durbanville</label>
              <label><input type="radio" name="campus" value="melkbos" /> Melkbos</label>
            </div>
          </div>
          <div class="form-group">
            <label for="start-date">Preferred Start Date</label>
            <input type="date" id="start-date" name="start-date" />
          </div>
          <div class="form-group">
            <label for="questions">Any Questions or Comments?</label>
            <textarea id="questions" name="questions" rows="4"></textarea>
          </div>
          <button type="submit" class="btn btn-green" style="width:100%;font-size:1.05rem;padding:0.9rem;">Send</button>
        </form>
        <p style="text-align:center;font-size:0.85rem;color:var(--text-light);margin-top:1rem;">
          By submitting this form you agree to our privacy policy. We will contact you within 2 business days.
        </p>
      </div>
    </div>
  </section>
</Layout>
