---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lily House Montessori Schools — Cape Town" description="Montessori Schools in Cape Town with three campuses in Claremont, Durbanville, and Melkbos. Enrolling now for 2026.">
  <!-- Hero Section -->
  <section class="hero">
    <img
      class="hero-bg"
      src="https://images.unsplash.com/photo-1509062522246-3755977927d7?w=1200&q=75"
      alt="Montessori classroom"
      loading="eager"
    />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <span class="hero-badge">Claremont · Durbanville · Melkbos</span>
      <h1>Where curiosity<br />finds its wings</h1>
      <p class="subtitle">
        Authentic Montessori education for children 18 months to 6 years across three Cape Town campuses.
      </p>
      <div class="hero-actions">
        <a href="/contact" class="btn btn-accent btn-lg">Book a Tour</a>
        <a href="/admissions" class="btn btn-primary btn-lg">Enroll Now</a>
      </div>
    </div>
  </section>

  <!-- Find Your Campus Section -->
  <section class="section" id="campuses">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Our Campuses</span>
        <h2 class="section-title">Find Your Campus</h2>
        <p class="section-desc">Three unique locations, one Montessori philosophy. Visit the campus that feels like home.</p>
      </div>
      <div class="campus-grid">
        <a href="/contact#claremont" class="campus-card-featured">
          <div class="campus-image">
            <img src="https://images.unsplash.com/photo-1580582932707-520aed937b7b?w=600&q=80" alt="Claremont Campus" loading="lazy" />
          </div>
          <div class="campus-info">
            <h3>Claremont</h3>
            <p>Queen Victoria Road — our original campus in the leafy Southern Suburbs</p>
            <span class="campus-link">Explore Claremont →</span>
          </div>
        </a>
        <a href="/contact#durbanville" class="campus-card-featured">
          <div class="campus-image">
            <img src="https://images.unsplash.com/photo-1571260899304-425eee4c7efc?w=600&q=80" alt="Durbanville Campus" loading="lazy" />
          </div>
          <div class="campus-info">
            <h3>Durbanville</h3>
            <p>Hooggelegen Road — farm-based learning in the Durbanville valley</p>
            <span class="campus-link">Explore Durbanville →</span>
          </div>
        </a>
        <a href="/contact#melkbos" class="campus-card-featured">
          <div class="campus-image">
            <img src="https://images.unsplash.com/photo-1503454537195-1dcabb73ffb9?w=600&q=80" alt="Melkbos Campus" loading="lazy" />
          </div>
          <div class="campus-info">
            <h3>Melkbos</h3>
            <p>Charles Hoffe Avenue — coastal Montessori on the West Coast</p>
            <span class="campus-link">Explore Melkbos →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Philosophy Section -->
  <section class="section section-alt">
    <div class="container">
      <div class="split-grid">
        <div class="split-content">
          <span class="section-tag">Our Philosophy</span>
          <h2 class="section-title" style="text-align:left;">A foundation for lifelong learning</h2>
          <p>At Lily House, we believe every child is naturally curious and capable. Our Montessori approach nurtures independence, builds confidence, and empowers children to become capable learners prepared for life.</p>
          <a href="/about" class="btn btn-primary" style="margin-top:1.5rem;">Learn More About Us</a>
        </div>
        <div class="split-visual">
          <img src="https://images.unsplash.com/photo-1588072432836-e10032774350?w=600&q=75" alt="Montessori classroom" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Blog Preview -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">From Our Community</span>
        <h2 class="section-title">Latest Updates</h2>
      </div>
      <div class="grid-2">
        <article class="blog-card-featured">
          <img src="https://images.unsplash.com/photo-1580582932707-520aed937b7b?w=600&q=80" alt="Montessori at home" loading="lazy" />
          <div class="blog-card-body">
            <time>15 June 2026</time>
            <h3>Montessori at Home: Creating a Prepared Environment</h3>
            <p>Simple ways to extend the Montessori philosophy into your home environment.</p>
            <a href="/blog/post-1" class="read-more">Read More →</a>
          </div>
        </article>
        <article class="blog-card-featured">
          <img src="https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=600&q=80" alt="Practical life skills" loading="lazy" />
          <div class="blog-card-body">
            <time>2 June 2026</time>
            <h3>Why Practical Life Skills Matter</h3>
            <p>How everyday activities build fine motor skills, concentration, and confidence.</p>
            <a href="/blog/post-2" class="read-more">Read More →</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="section section-alt">
    <div class="container">
      <div class="cta-banner">
        <h2>Start Your Child's Adventure</h2>
        <p>Give your child the gift of a Montessori education. Book a tour today and discover the Lily House difference.</p>
        <a href="/contact" class="btn btn-accent btn-lg">Book a Visit</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Section header */
  .section-header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 3rem;
  }
  .section-tag {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--primary);
    margin-bottom: 0.75rem;
    position: relative;
  }
  .section-tag::before {
    content: '';
    display: block;
    width: 24px;
    height: 3px;
    background: var(--primary);
    border-radius: 2px;
    margin: 0 auto 0.75rem;
  }
  .section-desc {
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin-top: 0.5rem;
  }
  .section-desc, .section-title {
    text-align: center;
  }

  /* Hero badge */
  .hero-badge {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(4px);
    padding: 0.4rem 1rem;
    border-radius: 2rem;
    margin-bottom: 1rem;
  }
  .hero-badge::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
    margin-right: 0.5rem;
    vertical-align: middle;
  }
  .hero h1 {
    font-size: 3rem;
  }
  .btn-lg {
    padding: 0.85rem 2.2rem;
    font-size: 1rem;
  }

  /* Campus cards */
  .campus-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .campus-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .campus-card-featured {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--white);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    transition: transform 0.3s, box-shadow 0.3s;
    text-decoration: none;
    color: inherit;
  }
  .campus-card-featured:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
  }
  .campus-image {
    height: 220px;
    overflow: hidden;
  }
  .campus-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s;
  }
  .campus-card-featured:hover .campus-image img {
    transform: scale(1.05);
  }
  .campus-info {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .campus-info h3 {
    font-size: 1.25rem;
    margin: 0;
  }
  .campus-info p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
    flex: 1;
  }
  .campus-link {
    color: var(--primary);
    font-weight: 600;
    font-size: 0.9rem;
    margin-top: 0.5rem;
  }

  /* Split layout */
  .split-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 768px) {
    .split-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .split-content p {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-top: 1rem;
  }
  .split-visual img {
    width: 100%;
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
  }

  /* Blog cards */
  .blog-card-featured {
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--white);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .blog-card-featured:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  .blog-card-featured img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }
  .blog-card-body {
    padding: 1.5rem;
  }
  .blog-card-body time {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }
  .blog-card-body h3 {
    font-size: 1.15rem;
    margin: 0.5rem 0;
  }
  .blog-card-body p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .read-more {
    display: inline-block;
    margin-top: 0.75rem;
    font-weight: 600;
    color: var(--primary);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2rem !important;
    }
    .hero-badge {
      font-size: 0.7rem;
    }
    .btn-lg {
      padding: 0.7rem 1.5rem;
      font-size: 0.9rem;
    }
    .campus-image {
      height: 180px;
    }
    .split-grid {
      gap: 2rem;
    }
  }
</style>
