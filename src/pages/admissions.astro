---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Admissions — Lily House Montessori Schools" description="Enroll at Lily House Montessori Schools. View fees, book a tour, and apply online for our Claremont, Durbanville, and Melkbos campuses.">
  <!-- Hero -->
  <section class="hero">
    <img
      class="hero-bg"
      src="https://images.unsplash.com/photo-1596464716127-f2a82984de30?w=1600&q=80"
      alt="Children at play"
      loading="eager"
    />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>Admissions</h1>
      <p class="subtitle">Join the Lily House family</p>
    </div>
  </section>

  <!-- Enrollment Process -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Enrollment Process</h2>
      <div class="grid-3">
        <div class="step">
          <div class="step-number">1</div>
          <h3>Book a Tour</h3>
          <p style="color:var(--text-secondary);">Visit your preferred campus to see our Montessori environments in action and meet our educators.</p>
        </div>
        <div class="step">
          <div class="step-number">2</div>
          <h3>Apply Online</h3>
          <p style="color:var(--text-secondary);">Complete our online enrollment form below and submit the required documentation.</p>
        </div>
        <div class="step">
          <div class="step-number">3</div>
          <h3>Welcome to Lily House</h3>
          <p style="color:var(--text-secondary);">We'll confirm your placement and welcome your family into our community.</p>
        </div>
      </div>
      <div class="text-center mt-2">
        <a href="/contact" class="btn btn-accent" style="font-size:1.05rem;">Book a Tour</a>
      </div>
    </div>
  </section>

  <!-- Fee Tables -->
  <section class="section" style="background:var(--card-bg);">
    <div class="container">
      <h2 class="section-title">Fees for 2026</h2>

      <!-- Claremont Fees -->
      <div style="margin-bottom:3rem;">
        <h3 style="font-size:1.4rem;margin-bottom:1rem;color:var(--primary);">Claremont Campus</h3>
        <div style="overflow-x:auto;">
          <table class="fee-table">
            <thead>
              <tr>
                <th>Fee Type</th>
                <th>Amount</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Enrolment Fee (once-off)</td>
                <td class="fee-amount">R3,500</td>
              </tr>
              <tr>
                <td>Toddler (18–36 months) — Half Day</td>
                <td class="fee-amount">R4,190 / month</td>
              </tr>
              <tr>
                <td>Toddler (18–36 months) — Full Day</td>
                <td class="fee-amount">R5,270 / month</td>
              </tr>
              <tr>
                <td>Annual Resource Fee</td>
                <td class="fee-amount">R1,500</td>
              </tr>
            </tbody>
          </table>
        </div>
        <h4 style="margin-top:1.5rem;margin-bottom:0.5rem;">Optional Extras</h4>
        <div style="overflow-x:auto;">
          <table class="fee-table">
            <thead>
              <tr>
                <th>Extra</th>
                <th>Cost</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Aftercare</td>
                <td class="fee-amount">R90 / day</td>
              </tr>
              <tr>
                <td>Lunch</td>
                <td class="fee-amount">R550 / month</td>
              </tr>
              <tr>
                <td>Holiday Club — Half Day</td>
                <td class="fee-amount">R170 / day</td>
              </tr>
              <tr>
                <td>Holiday Club — Full Day</td>
                <td class="fee-amount">R240 / day</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Durbanville Fees placeholder -->
      <div style="margin-bottom:3rem;">
        <h3 style="font-size:1.4rem;margin-bottom:1rem;color:var(--primary);">Durbanville Campus</h3>
        <p style="color:var(--text-secondary);">Please contact the Durbanville campus directly for the latest fee schedule.</p>
        <a href="/contact#durbanville" class="btn btn-outline" style="margin-top:0.5rem;display:inline-block;">Contact Durbanville</a>
      </div>

      <!-- Melkbos Fees placeholder -->
      <div>
        <h3 style="font-size:1.4rem;margin-bottom:1rem;color:var(--primary);">Melkbos Campus</h3>
        <p style="color:var(--text-secondary);">Please contact the Melkbos campus directly for the latest fee schedule.</p>
        <a href="/contact#melkbos" class="btn btn-outline" style="margin-top:0.5rem;display:inline-block;">Contact Melkbos</a>
      </div>
    </div>
  </section>

  <!-- Enrollment Form -->
  <section class="section">
    <div class="container">
      <div style="max-width:700px;margin:0 auto;">
        <h2 class="section-title">Online Enrollment</h2>
        <p style="text-align:center;color:var(--text-secondary);margin-bottom:2rem;">Complete the form below to begin your child's journey at Lily House Montessori.</p>
        <form action="#" method="POST" style="background:var(--card-bg);padding:2rem;border-radius:var(--radius);">
          <div class="form-group">
            <label for="parent-name">Parent / Guardian Name *</label>
            <input type="text" id="parent-name" name="parent-name" required />
          </div>
          <div class="form-group">
            <label for="child-name">Child's Full Name *</label>
            <input type="text" id="child-name" name="child-name" required />
          </div>
          <div class="form-group">
            <label for="email">Email Address *</label>
            <input type="email" id="email" name="email" required />
          </div>
          <div class="form-group">
            <label for="phone">Phone Number *</label>
            <input type="tel" id="phone" name="phone" required />
          </div>
          <div class="form-group">
            <label for="dob">Child's Date of Birth *</label>
            <input type="date" id="dob" name="dob" required />
          </div>
          <div class="form-group">
            <label>Preferred Campus *</label>
            <div class="radio-group">
              <label><input type="radio" name="campus" value="claremont" required /> Claremont</label>
              <label><input type="radio" name="campus" value="durbanville" /> Durbanville</label>
              <label><input type="radio" name="campus" value="melkbos" /> Melkbos</label>
            </div>
          </div>
          <div class="form-group">
            <label for="start-date">Preferred Start Date *</label>
            <input type="date" id="start-date" name="start-date" required />
          </div>
          <div class="form-group">
            <label for="questions">Questions or Comments</label>
            <textarea id="questions" name="questions" rows="4" placeholder="Any additional information we should know..."></textarea>
          </div>
          <button type="submit" class="btn btn-accent" style="width:100%;font-size:1.05rem;padding:0.9rem;">Submit Enrollment Request</button>
        </form>
        <p style="text-align:center;font-size:0.85rem;color:var(--text-secondary);margin-top:1rem;">
          By submitting this form you agree to our privacy policy. We will contact you within 2 business days.
        </p>
      </div>
    </div>
  </section>
</Layout>
