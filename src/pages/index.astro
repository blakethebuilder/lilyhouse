---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lily House Montessori Schools — Cape Town">
  <section class="hero">
    <img class="hero-bg-img" src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Evie-Toua-6-9-Educator.jpg?fit=1200%2C800&ssl=1" alt="" loading="eager" />
    <div class="hero-overlay"></div>
    <div class="container">
      <div class="hero-content">
        <h1>Lily House Montessori<br />Schools in Cape Town</h1>
        <p class="subtitle">We offer independent Montessori preschool and primary education across three unique campuses in Claremont, Durbanville, and Melkbos.</p>
        <a href="/contact" class="btn btn-green">Contact Us</a>
      </div>
    </div>
  </section>

  <section class="section" id="campuses">
    <div class="container">
      <h2 class="section-title">Find Your Campus</h2>
      <div class="campus-grid">
        <a href="/contact#claremont" class="campus-card-link">
          <img src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Jaxon_B_Candid-1.jpg?fit=800%2C534&ssl=1" alt="Claremont classroom" loading="lazy" />
          <div class="campus-card-body">
            <h3>Lily House Claremont</h3>
            <p>Small class sizes and personalised attention in the heart of the leafy Southern Suburbs.</p>
          </div>
        </a>
        <a href="/contact#durbanville" class="campus-card-link">
          <img src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/02/Lily-House-52-scaled.jpg?fit=800%2C534&ssl=1" alt="Durbanville classroom" loading="lazy" />
          <div class="campus-card-body">
            <h3>Lily House Durbanville</h3>
            <p>Our Durbanville campus offers a unique learning experience, where education blossoms amidst the rolling vineyards and orchards of the valley.</p>
          </div>
        </a>
        <a href="/contact#melkbos" class="campus-card-link">
          <img src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Lily-House-14.jpg?fit=800%2C534&ssl=1" alt="Melkbos classroom" loading="lazy" />
          <div class="campus-card-body">
            <h3>Lily House Melkbos</h3>
            <p>A nurturing, intimate school environment where coastal charm meets Montessori excellence on the West Coast.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">From the Lily House Community</h2>
      <p class="text-center" style="color:var(--text-light);margin-bottom:2rem;">Stories, updates, and Montessori insights from our classrooms to your home.</p>
      <div class="blog-grid">
        <article class="blog-card">
          <img src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Jess-Hanafey-Principal-6-9-Educator-Creative-Communications-Lead.jpg?fit=300%2C200&ssl=1" alt="Jess Hanafey" loading="lazy" />
          <div class="blog-card-body">
            <time>April 28, 2026</time>
            <h3><a href="/blog/montessori-melkbos-unique">Montessori School Melkbos: What Makes Lily House Unique on the West Coast</a></h3>
            <p>Comparing schools in Melkbosstrand? Read about our private Montessori school in Melkbos.</p>
            <a href="/blog/montessori-melkbos-unique" class="read-more">Read More »</a>
          </div>
        </article>
        <article class="blog-card">
          <img src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/02/Lily-House-104-scaled.jpg?fit=300%2C200&ssl=1" alt="Durbanville campus" loading="lazy" />
          <div class="blog-card-body">
            <time>April 13, 2026</time>
            <h3><a href="/blog/leading-montessori-durbanville">Why Lily House Is the Leading Montessori School in Durbanville</a></h3>
            <p>A look inside our farm-based Montessori campus in Durbanville.</p>
            <a href="/blog/leading-montessori-durbanville" class="read-more">Read More »</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container text-center">
      <div class="cta-banner">
        <h2>Start Your Child's Adventure</h2>
        <p>We prepare children for their next educational step and beyond. Book a tour or enroll today.</p>
        <a href="/contact" class="btn btn-green" style="font-size:1.05rem;padding:0.85rem 2.5rem;">Book a Visit</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .campus-grid { display:grid; grid-template-columns:1fr; gap:2rem; }
  @media (min-width:768px) { .campus-grid { grid-template-columns:repeat(3,1fr); } }

  .campus-card-link {
    border-radius:1rem; overflow:hidden; background:var(--white);
    box-shadow:0 4px 16px rgba(0,0,0,0.06); text-decoration:none; color:inherit;
    transition:transform 0.3s, box-shadow 0.3s;
  }
  .campus-card-link:hover { transform:translateY(-4px); box-shadow:0 12px 32px rgba(0,0,0,0.1); }
  .campus-card-link img { width:100%; height:240px; object-fit:cover; }
  .campus-card-body { padding:1.25rem; }
  .campus-card-body h3 { font-size:1.15rem; font-weight:700; margin-bottom:0.5rem; color:var(--teal); }
  .campus-card-body p { font-size:0.9rem; color:var(--text-light); line-height:1.6; }

  .blog-grid { display:grid; grid-template-columns:1fr; gap:2rem; }
  @media (min-width:768px) { .blog-grid { grid-template-columns:repeat(2,1fr); } }
</style>
