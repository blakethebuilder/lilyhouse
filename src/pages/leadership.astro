---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Our Leadership — Lily House Montessori Schools" description="Meet the leadership team behind Lily House Montessori Schools — Caitlin Brint and our dedicated educators guiding Montessori excellence across Cape Town.">
  <section class="page-hero">
    <div class="container">
      <h1>Our Leadership</h1>
      <p class="subtitle">Meet the dedicated executive team guiding the vision, values, and growth of all Lily House schools</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="leadership-block">
        <div class="leadership-img">
          <img src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Caitlin-Brint_Head-of-Schools1.jpg?fit=800%2C534&ssl=1" alt="Caitlin Brint, Head of Schools" loading="lazy" />
        </div>
        <div class="leadership-content">
          <h2 style="color:var(--teal);margin-bottom:1rem;">A Message to Our Parents</h2>
          <p style="color:var(--text-light);line-height:1.7;margin-bottom:1rem;">At Lily House, every child's journey matters deeply to us. Alongside Jacques and Steve, I lead a team that is committed to nurturing not just young minds, but the families and communities that support them. Together, we've built a foundation where authentic Montessori education thrives — one that respects each child's unique path while fostering excellence and care across all three of our campuses.</p>
          <p style="color:var(--text-light);line-height:1.7;margin-bottom:1rem;">Thank you for trusting us with your child's growth. We are here for you, always.</p>
          <p style="font-family:'Brush Script MT','Great Vibes',cursive;font-size:1.4rem;color:var(--teal);margin-top:1.5rem;">Caitlin Brint</p>
          <div style="margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid #e5e7eb;">
            <p style="font-weight:700;color:var(--teal);margin-bottom:0.25rem;">Caitlin Brint</p>
            <p style="color:var(--text-light);font-size:0.9rem;">Head of Schools</p>
            <p style="margin-top:0.5rem;"><a href="mailto:caitlin@lilyhouseschool.co.za" style="color:var(--teal);">caitlin@lilyhouseschool.co.za</a></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt text-center">
    <div class="container">
      <h2 class="section-title">See Our Vision in Action</h2>
      <p style="color:var(--text-light);margin-bottom:2rem;max-width:600px;margin-left:auto;margin-right:auto;">Our leadership's commitment to quality and community is present in every one of our campuses. We invite you to explore them or learn more about our philosophy.</p>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;">
        <a href="/admissions" class="btn btn-green">Enroll Now</a>
        <a href="/contact" class="btn btn-teal">Book a Tour</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero { background:linear-gradient(135deg, var(--teal), var(--teal-dark)); padding:5rem 0 3rem; text-align:center; color:var(--white); }
  .page-hero h1 { font-size:2.5rem; margin-bottom:0.5rem; color:var(--white); }
  .page-hero .subtitle { font-size:1.1rem; opacity:0.9; color:var(--white); }
  @media (min-width:768px) { .page-hero { padding:7rem 0 4rem; } .page-hero h1 { font-size:3rem; } }

  .leadership-block { display:grid; grid-template-columns:1fr; gap:2rem; align-items:center; }
  @media (min-width:768px) { .leadership-block { grid-template-columns:1fr 1fr; } }
  .leadership-img img { width:100%; border-radius:var(--radius); box-shadow:var(--shadow); }
  .leadership-content { max-width:600px; }
  .leadership-content h2 { font-size:1.5rem; }
  @media (min-width:768px) { .leadership-content h2 { font-size:1.8rem; } }
</style>