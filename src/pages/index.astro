---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lily House Montessori Schools — Cape Town" description="Montessori Schools in Cape Town with three campuses in Claremont, Durbanville, and Melkbos. Enrolling now for 2026.">
  <!-- Hero Section -->
  <section class="hero">
    <img
      class="hero-bg"
      src="https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=800&q=75"
      alt="Children learning at Lily House Montessori"
      loading="eager"
    />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>Lily House Montessori Schools in Cape Town</h1>
      <p class="subtitle">
        Three nurturing campuses in Claremont, Durbanville &amp; Melkbos — offering authentic Montessori education for children 18 months to 6 years.
      </p>
      <div class="hero-actions">
        <a href="/contact" class="btn btn-accent" style="font-size:1.05rem;padding:0.8rem 2rem;">Book a Tour</a>
        <a href="/admissions" class="btn" style="background:#00729A;color:white;font-size:1.05rem;padding:0.8rem 2rem;border-radius:2rem;">Enroll Now</a>
      </div>
    </div>
  </section>

  <!-- Find Your Campus Section -->
  <section class="section section-alt" id="campuses">
    <div class="container">
      <h2 class="section-title">Find Your Campus</h2>
      <div class="grid-3">
        <div class="card">
          <img
            src="https://images.unsplash.com/photo-1580582932707-520aed937b7b?w=600&q=80"
            alt="Claremont Campus"
            style="width:100%;height:200px;object-fit:cover;border-radius:0.5rem;margin-bottom:1rem;"
            loading="lazy"
          />
          <h3>Claremont</h3>
          <p>Located on Queen Victoria Road, our Claremont campus offers a warm, welcoming environment where children explore, discover, and grow at their own pace.</p>
          <a href="/contact#claremont" class="btn btn-outline" style="margin-top:1rem;display:inline-block;">Learn More</a>
        </div>
        <div class="card">
          <img
            src="https://images.unsplash.com/photo-1571260899304-425eee4c7efc?w=600&q=80"
            alt="Durbanville Campus"
            style="width:100%;height:200px;object-fit:cover;border-radius:0.5rem;margin-bottom:1rem;"
            loading="lazy"
          />
          <h3>Durbanville</h3>
          <p>Nestled in Hooggelegen Road, our Durbanville campus combines modern Montessori practices with a beautiful, child-centred space.</p>
          <a href="/contact#durbanville" class="btn btn-outline" style="margin-top:1rem;display:inline-block;">Learn More</a>
        </div>
        <div class="card">
          <img
            src="https://images.unsplash.com/photo-1503454537195-1dcabb73ffb9?w=600&q=80"
            alt="Melkbos Campus"
            style="width:100%;height:200px;object-fit:cover;border-radius:0.5rem;margin-bottom:1rem;"
            loading="lazy"
          />
          <h3>Melkbos</h3>
          <p>Our Melkbos campus on Charles Hoffe Avenue offers a seaside Montessori experience with spacious classrooms and outdoor learning.</p>
          <a href="/contact#melkbos" class="btn btn-outline" style="margin-top:1rem;display:inline-block;">Learn More</a>
        </div>
      </div>
    </div>
  </section>

  <!-- From the Lily House Community (Blog Preview) -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">From the Lily House Community</h2>
      <div class="grid-2">
        <div class="blog-card">
          <p class="date">15 June 2026</p>
          <h3>Montessori at Home: Creating a Prepared Environment</h3>
          <p>Simple ways to extend the Montessori philosophy into your home environment, supporting independence and concentration in young children.</p>
          <a href="/blog/post-1" class="read-more">Read More →</a>
        </div>
        <div class="blog-card">
          <p class="date">2 June 2026</p>
          <h3>Why Practical Life Skills Matter in Early Childhood</h3>
          <p>Discover how everyday activities like pouring, sweeping, and buttoning build fine motor skills, concentration, and confidence in Montessori classrooms.</p>
          <a href="/blog/post-2" class="read-more">Read More →</a>
        </div>
      </div>
      <div class="text-center mt-2">
        <a href="/blog" class="btn btn-primary">View All Posts</a>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="section">
    <div class="container">
      <div
        class="cta-banner"
        style="
          background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('https://images.unsplash.com/photo-1596464716127-f2a82984de30?w=800&q=75') center/cover;
          background-blend-mode: overlay;
        "
      >
        <h2>Start Your Child's Adventure</h2>
        <p>Give your child the gift of a Montessori education. Book a tour today and discover the Lily House difference.</p>
        <a href="/contact" class="btn btn-accent" style="font-size:1.1rem;padding:0.9rem 2.5rem;">Book a Visit</a>
      </div>
    </div>
  </section>
</Layout>
