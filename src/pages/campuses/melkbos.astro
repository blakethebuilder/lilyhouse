---
import Layout from '../../layouts/Layout.astro';
const team = [
  { name:'Jess Hanafey', role:'Campus Lead and 6-9 Guide', img:'https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Jess-Hanafey-Principal-6-9-Educator-Creative-Communications-Lead.jpg?fit=400%2C534&ssl=1' },
  { name:'Nqobile Sihlayi', role:'18 months – 3 years Educator', img:'https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Nqobile-Sihlayi-18-months-to-3-years-Educator-.jpg?fit=400%2C534&ssl=1' },
  { name:'Jenine Jonkerman', role:'3-6 Educator', img:'https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Jenine-Jonkerman-3-6-Educator-1.jpg?fit=400%2C534&ssl=1' },
  { name:'Elisa Da Silva', role:'3-6 Educator', img:'https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Elisa-Da-Silva-3-6-Educator-1.jpg?fit=400%2C534&ssl=1' },
  { name:'Evie Toua', role:'6-9 Educator', img:'https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Evie-Toua-6-9-Educator.jpg?fit=400%2C534&ssl=1' },
  { name:'Izabel Dean', role:'9-12 Educator', img:'https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Izabel-Dean-9-12-Educator-.jpg?fit=400%2C534&ssl=1' },
  { name:'Gabriella Otte', role:'Administrator', img:'https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Gabriella-Otte-Administrator-1.jpg?fit=400%2C534&ssl=1' },
  { name:'Franche Eloff', role:'Aftercare Educator', img:'https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Franche-Eloff-Aftercare-Educator-1.jpg?fit=400%2C534&ssl=1' },
  { name:'Monis Muhambi', role:'Head Chef', img:'https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Monis-Muhambi-Chef-.jpg?fit=400%2C534&ssl=1' },
];
const values = [
  { title:'Prepared Environments', desc:'Safe, stimulating, and nurturing spaces for learning.' },
  { title:'Complete Wellness', desc:'Supporting the physical, emotional, and social well-being of each child.' },
  { title:'Self & Creative Expression', desc:'Opportunities for art, music, movement, and imaginative play.' },
  { title:'Child-Centred Learning', desc:'A curriculum designed to meet the individual needs and interests of each child.' },
];
---

<Layout title="Melkbos Campus — Lily House Montessori Schools">
  <section class="hero">
    <img class="hero-bg-img" src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Lily-House-39.jpg?fit=1200%2C800&ssl=1" alt="" loading="eager" />
    <div class="hero-overlay"></div>
    <div class="container">
      <div class="hero-content">
        <h1>Lily House Melkbos:<br />Seaside Nurturing</h1>
        <p class="subtitle">Welcome to our hidden gem on the West Coast, where education is reimagined in a nurturing, intimate setting. We provide a safe, holistic, and inclusive environment where children are encouraged to explore, grow, and thrive.</p>
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
          <a href="https://wa.me/27745497336" class="btn btn-green" target="_blank" rel="noopener">Start WhatsApp Chat</a>
          <a href="/admissions" class="btn btn-teal">Enroll Now</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Why Choose Our Melkbos Campus?</h2>
      <div class="grid-3">
        <div class="pillar-card"><h3 style="color:var(--teal);margin-bottom:0.5rem;">Coastal Character</h3><p style="color:var(--text-light);">Our location in beautiful Melkbos provides a relaxed, inspiring, and calm learning environment. This serene setting is perfect for focused, child-led exploration.</p></div>
        <div class="pillar-card"><h3 style="color:var(--teal);margin-bottom:0.5rem;">Holistic Education</h3><p style="color:var(--text-light);">We focus on educating the whole child. Our Preschool and Primary programs nurture intellectual, emotional, and social development at every stage.</p></div>
        <div class="pillar-card"><h3 style="color:var(--teal);margin-bottom:0.5rem;">Strong Community</h3><p style="color:var(--text-light);">Our small, close-knit environment ensures individualised learning and meaningful connections. We are a supportive community of families and educators working together.</p></div>
      </div>
      <div class="values-grid" style="margin-top:2rem;">
        {values.map(v => (<div class="value-card"><h3>{v.title}</h3><p>{v.desc}</p></div>))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">Meet the Melkbos Team</h2>
      <p class="text-center" style="color:var(--text-light);margin-bottom:2rem;">Our passionate educators are the heart of our nurturing seaside community, dedicated to guiding each child on their learning journey.</p>
      <div class="team-grid">
        {team.map(m => (
          <div class="team-card">
            {m.img ? <img src={m.img} alt={m.name} loading="lazy" /> : <div class="team-placeholder">{m.name.split(' ').map(n => n[0]).join('')}</div>}
            <div class="team-body"><h3>{m.name}</h3><p>{m.role}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt text-center">
    <h2 style="font-size:1.8rem;margin-bottom:0.5rem;">Tour Our Melkbos Campus</h2>
    <p style="color:var(--text-light);margin-bottom:1.5rem;">Come and experience our calm, coastal school for yourself. We'd love to show you around.</p>
    <a href="/contact" class="btn btn-teal" style="font-size:1.05rem;">Book a Tour</a>
  </section>
</Layout>
<style>
  .values-grid { display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; }
  @media (min-width:768px) { .values-grid { grid-template-columns:repeat(4,1fr); } }
  .value-card { background:var(--teal-light); border-radius:var(--radius); padding:1.5rem; text-align:center; }
  .value-card h3 { font-size:1rem; color:var(--teal); margin-bottom:0.5rem; font-weight:700; }
  .value-card p { font-size:0.85rem; color:var(--text-light); }
  .lead-block { display:grid; grid-template-columns:1fr; gap:2rem; align-items:center; }
  @media (min-width:768px) { .lead-block { grid-template-columns:1fr 1fr; } }
  .lead-block img { width:100%; border-radius:var(--radius); }
  .lead-info h2 { font-size:1.6rem; color:var(--teal); margin-bottom:1rem; }
  .lead-info p { margin-bottom:0.5rem; color:var(--text-light); }
  .lead-info a { color:var(--teal); }
  .team-grid { display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; }
  @media (min-width:768px) { .team-grid { grid-template-columns:repeat(3,1fr); } }
  .team-card { background:var(--white); border-radius:var(--radius); overflow:hidden; box-shadow:var(--shadow); transition:transform 0.3s ease, box-shadow 0.3s ease; }
  .team-card:hover { transform:translateY(-4px); box-shadow:var(--shadow-lg); }
  .team-card img { width:100%; height:260px; object-fit:cover; }
  .team-placeholder { width:100%; height:200px; background:var(--teal-light); display:flex; align-items:center; justify-content:center; font-size:2rem; font-weight:800; color:var(--teal); }
  .team-body { padding:1rem; }
  .team-body h3 { font-size:1rem; color:var(--teal); margin-bottom:0.25rem; }
  .team-body p { font-size:0.85rem; color:var(--text-light); }
</style>
