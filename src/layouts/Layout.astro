---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Lily House Montessori Schools',
  description = 'Montessori Schools in Cape Town — Claremont, Durbanville, Melkbos',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/assets/favicon.png" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --primary: #00729A;
      --primary-dark: #005a7a;
      --primary-light: rgba(0, 114, 154, 0.08);
      --accent: #009A4C;
      --accent-light: rgba(0, 154, 76, 0.1);
      --warm-white: #FDFCFB;
      --card-bg: #FFFFFF;
      --border: #E8E4E0;
      --border-light: #F0ECEA;
      --text: #2D2A28;
      --text-secondary: #6B6560;
      --text-muted: #9C9690;
      --white: #FFFFFF;
      --radius: 12px;
      --radius-lg: 20px;
      --shadow-sm: 0 1px 3px rgba(45, 42, 40, 0.04), 0 1px 2px rgba(45, 42, 40, 0.03);
      --shadow: 0 4px 16px rgba(45, 42, 40, 0.06), 0 1px 3px rgba(45, 42, 40, 0.04);
      --shadow-lg: 0 12px 40px rgba(45, 42, 40, 0.08), 0 4px 12px rgba(45, 42, 40, 0.05);
      --shadow-xl: 0 20px 60px rgba(45, 42, 40, 0.1), 0 8px 20px rgba(45, 42, 40, 0.06);
      --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Raleway', sans-serif;
      color: var(--text);
      background: var(--warm-white);
      line-height: 1.7;
      font-size: 1rem;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    a {
      color: var(--primary);
      text-decoration: none;
      transition: color var(--transition);
    }
    a:hover {
      color: var(--accent);
    }

    img {
      max-width: 100%;
      height: auto;
      display: block;
    }

    h1, h2, h3, h4 {
      font-family: 'Raleway', sans-serif;
      color: var(--primary-dark);
      line-height: 1.25;
      font-weight: 700;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    /* === HEADER === */
    .header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(255, 255, 255, 0.97);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border-light);
    }

    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.65rem 1.5rem;
      max-width: 1400px;
      margin: 0 auto;
    }

    .header-logo {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
    }
    .header-logo img {
      width: 48px;
      height: auto;
    }
    .header-logo span {
      font-weight: 800;
      font-size: 1.15rem;
      color: var(--primary);
      letter-spacing: -0.01em;
    }

    .nav {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }

    .nav a {
      font-weight: 500;
      font-size: 0.9rem;
      color: var(--text);
      padding: 0.5rem 0.9rem;
      border-radius: 8px;
      transition: background var(--transition), color var(--transition);
    }
    .nav a:hover {
      color: var(--primary);
      background: var(--primary-light);
    }

    .nav .dropdown {
      position: relative;
    }
    .nav .dropdown > a {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }
    .nav .dropdown-menu {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      background: var(--white);
      box-shadow: var(--shadow-lg);
      border-radius: var(--radius);
      padding: 0.5rem;
      min-width: 180px;
      margin-top: 0.35rem;
      border: 1px solid var(--border-light);
    }
    .nav .dropdown:hover .dropdown-menu,
    .nav .dropdown:focus-within .dropdown-menu {
      display: block;
    }
    .nav .dropdown-menu a {
      display: block;
      padding: 0.55rem 1rem;
      font-size: 0.875rem;
      border-radius: 6px;
    }
    .nav .dropdown-menu a:hover {
      background: var(--primary-light);
      color: var(--primary);
    }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }

    /* === BUTTONS === */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-family: 'Raleway', sans-serif;
      font-weight: 600;
      font-size: 0.9rem;
      padding: 0.65rem 1.5rem;
      border-radius: 50px;
      border: 2px solid transparent;
      cursor: pointer;
      transition: all var(--transition);
      text-align: center;
      text-decoration: none;
      gap: 0.4rem;
      letter-spacing: 0.01em;
    }
    .btn:hover {
      transform: translateY(-2px);
    }

    .btn-primary {
      background: var(--primary);
      color: var(--white);
      border-color: var(--primary);
    }
    .btn-primary:hover {
      background: var(--primary-dark);
      border-color: var(--primary-dark);
      box-shadow: 0 6px 20px rgba(0, 114, 154, 0.3);
      color: var(--white);
    }

    .btn-accent {
      background: var(--accent);
      color: var(--white);
      border-color: var(--accent);
    }
    .btn-accent:hover {
      background: #008340;
      border-color: #008340;
      box-shadow: 0 6px 20px rgba(0, 154, 76, 0.3);
      color: var(--white);
    }

    .btn-outline {
      background: transparent;
      color: var(--primary);
      border-color: var(--primary);
    }
    .btn-outline:hover {
      background: var(--primary);
      color: var(--white);
    }

    .btn-lg {
      padding: 0.85rem 2.2rem;
      font-size: 1rem;
    }

    .btn-sm {
      padding: 0.5rem 1.1rem;
      font-size: 0.85rem;
    }

    /* === FOOTER === */
    .footer {
      background: var(--primary-dark);
      color: var(--white);
      padding: 4rem 0 0;
      margin-top: 5rem;
      position: relative;
    }
    .footer::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, var(--accent), var(--primary), var(--accent));
    }
    .footer-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2.5rem;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }
    @media (min-width: 768px) {
      .footer-grid {
        grid-template-columns: 2fr 1fr 1.5fr;
      }
    }
    .footer h3 {
      color: var(--white);
      font-size: 0.85rem;
      margin-bottom: 1.25rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-weight: 700;
      opacity: 0.8;
    }
    .footer p, .footer a {
      color: rgba(255,255,255,0.8);
      font-size: 0.9rem;
      line-height: 1.8;
    }
    .footer a:hover {
      color: var(--white);
    }
    .footer-links {
      list-style: none;
    }
    .footer-links li {
      margin-bottom: 0.6rem;
    }
    .footer-links a {
      color: rgba(255,255,255,0.8);
      transition: color var(--transition), padding-left var(--transition);
      display: inline-block;
    }
    .footer-links a:hover {
      color: var(--white);
      padding-left: 4px;
    }
    .social-links {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      margin-top: 0.25rem;
    }
    .social-links a {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: rgba(255,255,255,0.8);
      font-size: 0.9rem;
      transition: color var(--transition);
    }
    .social-links a:hover {
      color: var(--white);
    }
    .footer-bottom {
      text-align: center;
      padding: 1.5rem;
      margin-top: 3rem;
      border-top: 1px solid rgba(255,255,255,0.1);
      font-size: 0.8rem;
      color: rgba(255,255,255,0.5);
    }

    /* === SECTION HELPERS === */
    .section {
      padding: 5rem 0;
    }
    .section-title {
      font-size: 2.2rem;
      text-align: center;
      margin-bottom: 1rem;
      color: var(--primary-dark);
    }
    .section-alt {
      background: var(--white);
    }

    .card {
      background: var(--card-bg);
      border-radius: var(--radius-lg);
      padding: 2rem;
      box-shadow: var(--shadow);
      border: 1px solid var(--border-light);
      transition: transform var(--transition), box-shadow var(--transition);
      overflow: hidden;
    }
    .card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-lg);
    }
    .card h3 {
      margin-bottom: 0.75rem;
      color: var(--primary-dark);
    }
    .card p {
      color: var(--text-secondary);
      font-size: 0.95rem;
      line-height: 1.7;
    }

    /* === HERO === */
    .hero {
      position: relative;
      min-height: max(70vh, 480px);
      display: flex;
      align-items: center;
      justify-content: flex-start;
      text-align: left;
      color: var(--white);
      overflow: hidden;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: 0;
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.2) 60%, rgba(0,0,0,0.1) 100%);
      z-index: 1;
    }
    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 680px;
      padding: 2.5rem;
    }
    .hero h1 {
      font-size: 3rem;
      color: var(--white);
      margin-bottom: 1rem;
      line-height: 1.15;
      font-weight: 800;
    }
    .hero p.subtitle {
      font-size: 1.2rem;
      margin-bottom: 2rem;
      opacity: 0.9;
      line-height: 1.6;
      font-weight: 400;
    }
    .hero-actions {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    /* === GRID LAYOUTS === */
    .grid-3 {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    @media (min-width: 768px) {
      .grid-3 {
        grid-template-columns: repeat(3, 1fr);
      }
    }
    .grid-2 {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    @media (min-width: 768px) {
      .grid-2 {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    /* === CTA BANNER === */
    .cta-banner {
      position: relative;
      background: linear-gradient(135deg, var(--primary) 0%, #003d52 100%);
      color: var(--white);
      text-align: center;
      padding: 4.5rem 2rem;
      border-radius: var(--radius-lg);
      overflow: hidden;
    }
    .cta-banner::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
      opacity: 0.5;
    }
    .cta-banner h2 {
      color: var(--white);
      font-size: 2.2rem;
      margin-bottom: 1rem;
      position: relative;
    }
    .cta-banner p {
      font-size: 1.1rem;
      margin-bottom: 2rem;
      opacity: 0.9;
      position: relative;
      max-width: 560px;
      margin-left: auto;
      margin-right: auto;
    }
    .cta-banner .btn {
      position: relative;
    }

    /* === BLOG CARD === */
    .blog-card {
      background: var(--white);
      border: 1px solid var(--border-light);
      border-radius: var(--radius-lg);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
      transition: transform var(--transition), box-shadow var(--transition);
    }
    .blog-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-lg);
    }
    .blog-card img {
      width: 100%;
      height: 220px;
      object-fit: cover;
    }
    .blog-card-body {
      padding: 1.5rem;
    }
    .blog-card .date {
      font-size: 0.8rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-weight: 500;
    }
    .blog-card h3 {
      margin: 0.6rem 0;
      font-size: 1.2rem;
      color: var(--text);
    }
    .blog-card h3 a {
      color: var(--text);
      transition: color var(--transition);
    }
    .blog-card h3 a:hover {
      color: var(--primary);
    }
    .blog-card p {
      color: var(--text-secondary);
      font-size: 0.9rem;
      line-height: 1.7;
    }
    .blog-card .read-more {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      margin-top: 0.75rem;
      font-weight: 600;
      font-size: 0.9rem;
      color: var(--primary);
      transition: gap var(--transition);
    }
    .blog-card .read-more:hover {
      gap: 0.6rem;
    }

    /* === CONTACT CAMPUS CARD === */
    .campus-card {
      background: var(--white);
      border: 1px solid var(--border-light);
      border-radius: var(--radius-lg);
      padding: 1.75rem;
      box-shadow: var(--shadow-sm);
      transition: transform var(--transition), box-shadow var(--transition);
    }
    .campus-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow);
    }
    .campus-card h3 {
      margin-bottom: 1rem;
      font-size: 1.3rem;
      color: var(--primary-dark);
    }
    .campus-card p {
      margin-bottom: 0.4rem;
      font-size: 0.9rem;
      color: var(--text-secondary);
    }
    .campus-card p strong {
      color: var(--text);
    }

    /* === FORM STYLING === */
    .form-group {
      margin-bottom: 1.25rem;
    }
    .form-group label {
      display: block;
      font-weight: 600;
      margin-bottom: 0.4rem;
      font-size: 0.9rem;
      color: var(--text);
    }
    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 0.8rem 1rem;
      border: 2px solid var(--border);
      border-radius: var(--radius);
      font-family: 'Raleway', sans-serif;
      font-size: 0.95rem;
      transition: border-color var(--transition), box-shadow var(--transition);
      background: var(--warm-white);
    }
    .form-group input:hover,
    .form-group select:hover,
    .form-group textarea:hover {
      border-color: #D0CCC8;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--primary);
      box-shadow: 0 0 0 4px var(--primary-light);
    }
    .form-group textarea {
      resize: vertical;
      min-height: 120px;
    }
    .radio-group {
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .radio-group label {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 400;
      cursor: pointer;
      font-size: 0.95rem;
    }
    .radio-group input[type="radio"] {
      width: auto;
      accent-color: var(--primary);
    }

    /* === FEE TABLE === */
    .fee-table {
      width: 100%;
      border-collapse: collapse;
      margin: 1rem 0;
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
    }
    .fee-table th, .fee-table td {
      padding: 0.85rem 1.25rem;
      text-align: left;
      border-bottom: 1px solid var(--border-light);
      font-size: 0.95rem;
    }
    .fee-table th {
      background: var(--primary);
      color: var(--white);
      font-weight: 600;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .fee-table tr:nth-child(even) {
      background: rgba(0, 114, 154, 0.03);
    }
    .fee-table tr:last-child td {
      border-bottom: none;
    }
    .fee-table .fee-amount {
      font-weight: 700;
      color: var(--primary);
      white-space: nowrap;
    }

    /* === STEPS === */
    .step {
      text-align: center;
      padding: 2rem 1.5rem;
    }
    .step-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--primary), var(--primary-dark));
      color: var(--white);
      font-weight: 800;
      font-size: 1.3rem;
      margin-bottom: 1.25rem;
      box-shadow: 0 4px 14px rgba(0, 114, 154, 0.25);
    }
    .step h3 {
      margin-bottom: 0.5rem;
      color: var(--primary-dark);
    }

    /* === MISC === */
    .text-center { text-align: center; }
    .mt-1 { margin-top: 1rem; }
    .mt-2 { margin-top: 2rem; }
    .mt-3 { margin-top: 3rem; }
    .mb-1 { margin-bottom: 1rem; }
    .mb-2 { margin-bottom: 2rem; }
    .mb-3 { margin-bottom: 3rem; }

    /* === PILLARS (About) === */
    .pillars {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    @media (min-width: 640px) {
      .pillars {
        grid-template-columns: repeat(3, 1fr);
      }
    }
    .pillar-card {
      background: var(--white);
      border-radius: var(--radius-lg);
      padding: 2.5rem 1.75rem;
      text-align: center;
      border: 1px solid var(--border-light);
      box-shadow: var(--shadow-sm);
      transition: transform var(--transition), box-shadow var(--transition);
      position: relative;
      overflow: hidden;
    }
    .pillar-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, var(--primary), var(--accent));
    }
    .pillar-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-lg);
    }
    .pillar-icon {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      display: block;
    }
    .pillar-card h3 {
      margin-bottom: 0.75rem;
      font-size: 1.15rem;
    }

    /* === PAGE HERO (inner pages) === */
    .page-hero {
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
      color: var(--white);
      padding: 4rem 0 3.5rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .page-hero::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: rgba(255,255,255,0.15);
    }
    .page-hero h1 {
      color: var(--white);
      font-size: 2.5rem;
      margin-bottom: 0.75rem;
      font-weight: 800;
    }
    .page-hero .subtitle {
      font-size: 1.1rem;
      opacity: 0.85;
      max-width: 600px;
      margin: 0 auto;
    }

    /* === BREADCRUMB === */
    .breadcrumb {
      margin-bottom: 1.5rem;
    }
    .breadcrumb a {
      color: rgba(255,255,255,0.7);
      text-decoration: none;
      font-weight: 500;
      font-size: 0.9rem;
      transition: color var(--transition);
    }
    .breadcrumb a:hover {
      color: var(--white);
    }

    /* === PROSE === */
    .prose {
      max-width: 720px;
      margin: 0 auto;
      line-height: 1.8;
      font-size: 1.05rem;
      color: var(--text);
    }
    .prose h2 {
      color: var(--primary-dark);
      margin-top: 2.5rem;
      font-size: 1.5rem;
    }
    .prose ul {
      padding-left: 1.5rem;
    }
    .prose li {
      margin-bottom: 0.6rem;
      line-height: 1.7;
    }
    .prose strong {
      color: var(--text);
    }
    .prose p {
      margin-bottom: 1.2rem;
    }

    /* === MOBILE NAV TOGGLES === */
    .nav-toggle {
      display: none;
      background: none;
      border: none;
      font-size: 1.5rem;
      cursor: pointer;
      color: var(--primary);
      padding: 0.35rem;
      border-radius: 8px;
      transition: background var(--transition);
    }
    .nav-toggle:hover {
      background: var(--primary-light);
    }

    @media (max-width: 900px) {
      .header-inner {
        flex-wrap: wrap;
        padding: 0.5rem 1rem;
      }
      .nav-toggle {
        display: block;
        font-size: 1.75rem;
        padding: 0.25rem;
      }
      .header-actions {
