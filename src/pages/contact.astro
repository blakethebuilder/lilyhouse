---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Lily House Montessori Schools">
  <section class="page-hero">
    <div class="container">
      <h1>Contact Us</h1>
      <p class="subtitle">We'd love to hear from you</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">Our Campuses</h2>
      <div class="grid-3">
        <div class="campus-detail" id="claremont">
          <h3>Claremont</h3>
          <p><strong>Head:</strong> Qaanita Hendricks</p>
          <p><strong>Email:</strong> <a href="mailto:qaanita@lilyhouseschool.co.za">qaanita@lilyhouseschool.co.za</a></p>
          <p><strong>Address:</strong> 80 Queen Victoria Road, Claremont</p>
        </div>
        <div class="campus-detail" id="durbanville">
          <h3>Durbanville</h3>
          <p><strong>Head:</strong> Tasneem Khan</p>
          <p><strong>Email:</strong> <a href="mailto:tasneem@lilyhouseschool.co.za">tasneem@lilyhouseschool.co.za</a></p>
          <p><strong>Address:</strong> 16 Hooggelegen Road, Durbanville</p>
        </div>
        <div class="campus-detail" id="melkbos">
          <h3>Melkbos</h3>
          <p><strong>Head:</strong> Jess Hanafey</p>
          <p><strong>Email:</strong> <a href="mailto:jess@lilyhouseschool.co.za">jess@lilyhouseschool.co.za</a></p>
          <p><strong>Address:</strong> 42 Charles Hoffe Avenue, Van Riebeekstrand</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container" style="max-width:600px;">
      <h2 class="section-title">Send Us a Message</h2>
      <form class="contact-form" action="/api/contact" method="POST">
        <input type="text" name="name" placeholder="Your Name *" required />
        <input type="email" name="email" placeholder="Email Address *" required />
        <textarea name="message" rows="5" placeholder="Message *" required></textarea>
        <button type="submit" class="btn btn-teal" style="width:100%;padding:0.9rem;font-size:1.05rem;">Send Message</button>
      </form>
    </div>
  </section>
</Layout>

<style>
  .campus-detail { background:var(--white); border-radius:var(--radius); padding:1.5rem; box-shadow:var(--shadow); }
  .campus-detail h3 { font-size:1.2rem; color:var(--teal); margin-bottom:0.75rem; }
  .campus-detail p { font-size:0.9rem; margin-bottom:0.4rem; color:var(--text-light); }
  .campus-detail a { color:var(--teal); }

  .contact-form { background:var(--white); padding:2rem; border-radius:var(--radius); }
  .contact-form input, .contact-form textarea {
    width:100%; padding:0.75rem 1rem; margin-bottom:1rem;
    border:2px solid #e5e7eb; border-radius:0.75rem;
    font-family:'Raleway',sans-serif; font-size:0.95rem;
  }
  .contact-form input:focus, .contact-form textarea:focus { outline:none; border-color:var(--teal); }
</style>
