---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lily House Montessori Schools — Cape Town" description="Montessori Schools in Cape Town with three campuses in Claremont, Durbanville, and Melkbos.">
  <!-- HERO -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-split">
        <div class="hero-text">
          <span class="hero-guarantee">✦ 100% Montessori Certified</span>
          <h1>Unlock Your<br />Child's Potential</h1>
          <p>We believe every child has unique talents waiting to be discovered. Our Montessori approach nurtures curiosity, independence, and a lifelong love of learning.</p>
          <div class="hero-actions">
            <a href="/contact" class="btn btn-green" style="padding:0.85rem 2rem;font-size:1rem;">Book a Tour</a>
            <a href="/admissions" class="btn btn-outline" style="padding:0.85rem 2rem;font-size:1rem;">Enroll Now →</a>
          </div>
        </div>
        <div class="hero-grid">
          <div class="hero-photo"><img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&q=75" alt="Child learning" loading="eager" /></div>
          <div class="hero-photo"><img src="https://images.unsplash.com/photo-1544717305-2782549b5136?w=400&q=75" alt="Child reading" loading="eager" /></div>
          <div class="hero-photo"><img src="https://images.unsplash.com/photo-1596464716127-f2a82984de30?w=400&q=75" alt="Child playing" loading="eager" /></div>
          <div class="hero-photo"><img src="https://images.unsplash.com/photo-1588072432836-e10032774350?w=400&q=75" alt="Child exploring" loading="eager" /></div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS BAR -->
  <div style="background:linear-gradient(135deg, var(--teal) 0%, var(--teal-dark) 100%);padding:2rem 0;">
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;text-align:center;color:var(--white);">
        <div>
          <div style="font-size:2.5rem;font-weight:900;line-height:1;">3</div>
          <div style="font-size:0.85rem;opacity:0.85;margin-top:0.25rem;">Campuses across Cape Town</div>
        </div>
        <div>
          <div style="font-size:2.5rem;font-weight:900;line-height:1;">18mo</div>
          <div style="font-size:0.85rem;opacity:0.85;margin-top:0.25rem;">to 6 years old</div>
        </div>
        <div>
          <div style="font-size:2.5rem;font-weight:900;line-height:1;">10+</div>
          <div style="font-size:0.85rem;opacity:0.85;margin-top:0.25rem;">Years of Montessori excellence</div>
        </div>
      </div>
    </div>
  </div>

  <!-- FIND YOUR CAMPUS -->
  <section class="section" id="campuses">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Our Campuses</span>
        <h2 class="section-title">Find Your Campus</h2>
        <p style="color:var(--text-light);">Three unique locations, one Montessori philosophy.</p>
      </div>
      <div class="campus-grid">
        <a href="/contact#claremont" class="campus-card" style="--card-accent: var(--teal);">
          <div class="campus-img">
            <img src="https://images.unsplash.com/photo-1580582932707-520aed937b7b?w=600&q=80" alt="Claremont" loading="lazy" />
          </div>
          <div class="campus-body">
            <h3>Claremont</h3>
            <p>Queen Victoria Road — our original campus in the leafy Southern Suburbs</p>
            <span class="campus-arrow">Explore →</span>
          </div>
        </a>
        <a href="/contact#durbanville" class="campus-card" style="--card-accent: var(--green);">
          <div class="campus-img">
            <img src="https://images.unsplash.com/photo-1571260899304-425eee4c7efc?w=600&q=80" alt="Durbanville" loading="lazy" />
          </div>
          <div class="campus-body">
            <h3>Durbanville</h3>
            <p>Hooggelegen Road — farm-based learning in the Durbanville valley</p>
            <span class="campus-arrow">Explore →</span>
          </div>
        </a>
        <a href="/contact#melkbos" class="campus-card" style="--card-accent: #D97706;">
          <div class="campus-img">
            <img src="https://images.unsplash.com/photo-1503454537195-1dcabb73ffb9?w=600&q=80" alt="Melkbos" loading="lazy" />
          </div>
          <div class="campus-body">
            <h3>Melkbos</h3>
            <p>Charles Hoffe Avenue — coastal Montessori on the West Coast</p>
            <span class="campus-arrow">Explore →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- PHILOSOPHY -->
  <section class="section section-teal">
    <div class="container">
      <div class="split-grid">
        <div class="split-content">
          <span class="section-tag">Our Philosophy</span>
          <h2 style="font-size:2rem;font-weight:800;margin-bottom:1rem;color:var(--text);">A foundation for lifelong learning</h2>
          <p style="color:var(--text-light);font-size:1.05rem;line-height:1.7;">At Lily House, we believe every child is naturally curious and capable. Our Montessori approach nurtures independence, builds confidence, and empowers children to become capable learners prepared for life.</p>
          <ul class="check-list">
            <li>✦ Hands-on learning with authentic Montessori materials</li>
            <li>✦ Individualised progress at each child's own pace</li>
            <li>✦ Practical life skills that build confidence</li>
          </ul>
          <a href="/about" class="btn btn-teal" style="margin-top:1.5rem;">Learn More About Us</a>
        </div>
        <div class="split-image">
          <div class="circle-frame">
            <img src="https://images.unsplash.com/photo-1588072432836-e10032774350?w=600&q=75" alt="Montessori classroom" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOG PREVIEW -->
  <section class="section section-cream">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">From Our Community</span>
        <h2 class="section-title">Latest Updates</h2>
      </div>
      <div class="grid-2">
        <article class="blog-card">
          <img src="https://images.unsplash.com/photo-1580582932707-520aed937b7b?w=700&q=80" alt="Montessori at home" loading="lazy" />
          <div class="blog-card-body">
            <time>15 June 2026</time>
            <h3>Montessori at Home: Creating a Prepared Environment</h3>
            <p>Simple ways to extend the Montessori philosophy into your home environment.</p>
            <a href="/blog/post-1" class="read-more">Read More →</a>
          </div>
        </article>
        <article class="blog-card">
          <img src="https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=700&q=80" alt="Practical life skills" loading="lazy" />
          <div class="blog-card-body">
            <time>2 June 2026</time>
            <h3>Why Practical Life Skills Matter</h3>
            <p>How everyday activities build fine motor skills, concentration, and confidence.</p>
            <a href="/blog/post-2" class="read-more">Read More →</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="cta-banner">
        <h2>Start Your Child's Adventure ✨</h2>
        <p>Give your child the gift of a Montessori education. Book a tour today.</p>
        <a href="/contact" class="btn btn-green" style="padding:0.85rem 2.5rem;font-size:1.05rem;">Book a Visit</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero split layout */
  .hero-section {
    padding: 4rem 0;
    background: linear-gradient(180deg, #f0f7fa 0%, var(--white) 100%);
    position: relative;
    overflow: hidden;
  }
  .hero-section::before {
    content: '';
    position: absolute;
    top: -100px; right: -100px;
    width: 400px; height: 400px;
    background: radial-gradient(circle, var(--teal-light) 0%, transparent 70%);
    border-radius: 50%;
    z-index: 0;
  }
  .hero-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  .hero-guarantee {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--teal);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }
  .hero-text h1 {
    font-size: 3rem;
    font-weight: 900;
    color: var(--text);
    line-height: 1.1;
    margin-bottom: 1rem;
  }
  .hero-text p {
    font-size: 1.1rem;
    color: var(--text-light);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 480px;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .btn-outline {
    background: transparent;
    color: var(--teal);
    border: 2px solid var(--teal);
  }
  .btn-outline:hover {
    background: var(--teal);
    color: var(--white);
  }

  /* Photo grid */
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  .hero-photo {
    border-radius: 1rem;
    overflow: hidden;
    aspect-ratio: 1;
    box-shadow: var(--shadow);
  }
  .hero-photo:nth-child(2) {
    margin-top: 2rem;
  }
  .hero-photo:nth-child(3) {
    margin-bottom: 2rem;
  }
  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Campus cards */
  .campus-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 768px) { .campus-grid { grid-template-columns: repeat(3, 1fr); } }

  .campus-card {
    display: flex; flex-direction: column; border-radius: var(--radius);
    overflow: hidden; background: var(--white); box-shadow: var(--shadow);
    border-top: 4px solid var(--card-accent, var(--teal));
    transition: transform 0.3s, box-shadow 0.3s; text-decoration: none; color: inherit;
  }
  .campus-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); }

  .campus-img { height: 200px; overflow: hidden; }
  .campus-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
  .campus-card:hover .campus-img img { transform: scale(1.08); }

  .campus-body { padding: 1.5rem; flex: 1; display: flex; flex-direction: column; gap: 0.4rem; }
  .campus-body h3 { font-size: 1.3rem; font-weight: 800; color: var(--card-accent, var(--teal)); }
  .campus-body p { color: var(--text-light); font-size: 0.9rem; line-height: 1.5; flex: 1; }
  .campus-arrow { font-weight: 700; color: var(--card-accent, var(--teal)); font-size: 0.9rem; transition: gap 0.2s; display: flex; align-items: center; gap: 0.25rem; }
  .campus-card:hover .campus-arrow { gap: 0.5rem; }

  /* Split layout */
  .split-grid { display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: center; }
  @media (min-width: 768px) { .split-grid { grid-template-columns: 1fr 1fr; } }

  .check-list { list-style: none; margin-top: 1.5rem; }
  .check-list li { padding: 0.4rem 0; font-size: 1rem; color: var(--text-light); }

  /* Circle frame */
  .circle-frame {
    width: 100%; max-width: 400px; margin: 0 auto;
    aspect-ratio: 1; border-radius: 50%; overflow: hidden;
    border: 6px solid var(--white); box-shadow: var(--shadow-lg);
  }
  .circle-frame img { width: 100%; height: 100%; object-fit: cover; }

  /* Mobile */
  @media (max-width: 768px) {
    .hero-split {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .hero-text h1 { font-size: 2rem; }
    .hero-text p { font-size: 1rem; }
    .hero-grid { gap: 0.5rem; }
    .hero-photo:nth-child(2) { margin-top: 1rem; }
    .hero-photo:nth-child(3) { margin-bottom: 1rem; }
    .hero-section { padding: 2rem 0; }
    .campus-img { height: 180px; }
    .circle-frame { max-width: 280px; }
    .split-grid { gap: 2rem; }
  }
</style>
