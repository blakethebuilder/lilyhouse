---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Lily House Montessori Schools" description="Get in touch with Lily House Montessori Schools. Find our Claremont, Durbanville, and Melkbos campuses, and book a tour.">
  <!-- Hero -->
  <section class="hero">
    <img
      class="hero-bg"
      src="https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=1600&q=80"
      alt="Contact Lily House Montessori"
      loading="eager"
    />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>Contact Us</h1>
      <p class="subtitle">We'd love to hear from you</p>
    </div>
  </section>

  <!-- Campus Details -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Our Campuses</h2>
      <div class="grid-3">
        <div class="campus-card" id="claremont">
          <h3>Claremont</h3>
          <p><strong>Head of School:</strong> Qaanita Hendricks</p>
          <p><strong>Email:</strong> <a href="mailto:qaanita@lilyhouseschool.co.za">qaanita@lilyhouseschool.co.za</a></p>
          <p><strong>Address:</strong> 80 Queen Victoria Road, Claremont</p>
          <div style="margin-top:1rem;border-radius:var(--radius);overflow:hidden;">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3310.084306981048!2d18.4653!3d-33.9782!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1dcc5a0b1b1b1b1b%3A0x1b1b1b1b1b1b1b1b!2s80%20Queen%20Victoria%20Rd%2C%20Claremont%2C%20Cape%20Town!5e0!3m2!1sen!2sza!4v1"
              width="100%"
              height="200"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Claremont campus map"
            ></iframe>
          </div>
        </div>
        <div class="campus-card" id="durbanville">
          <h3>Durbanville</h3>
          <p><strong>Head of School:</strong> Tasneem Khan</p>
          <p><strong>Email:</strong> <a href="mailto:tasneem@lilyhouseschool.co.za">tasneem@lilyhouseschool.co.za</a></p>
          <p><strong>Address:</strong> 16 Hooggelegen Road, Durbanville</p>
          <div style="margin-top:1rem;border-radius:var(--radius);overflow:hidden;">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3309.084306981048!2d18.6489!3d-33.8335!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1dcc5a0b1b1b1b1b%3A0x1b1b1b1b1b1b1b1b!2s16%20Hooggelegen%20Rd%2C%20Durbanville%2C%20Cape%20Town!5e0!3m2!1sen!2sza!4v1"
              width="100%"
              height="200"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Durbanville campus map"
            ></iframe>
          </div>
        </div>
        <div class="campus-card" id="melkbos">
          <h3>Melkbos</h3>
          <p><strong>Head of School:</strong> Jess Hanafey</p>
          <p><strong>Email:</strong> <a href="mailto:jess@lilyhouseschool.co.za">jess@lilyhouseschool.co.za</a></p>
          <p><strong>Address:</strong> 42 Charles Hoffe Avenue, Van Riebeekstrand</p>
          <div style="margin-top:1rem;border-radius:var(--radius);overflow:hidden;">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3309.084306981048!2d18.4469!3d-33.7278!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1dcc5a0b1b1b1b1b%3A0x1b1b1b1b1b1b1b1b!2s42%20Charles%20Hoffe%20Ave%2C%20Van%20Riebeekstrand%2C%20Cape%20Town!5e0!3m2!1sen!2sza!4v1"
              width="100%"
              height="200"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Melkbos campus map"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="section" style="background:var(--card-bg);">
    <div class="container">
      <div style="max-width:600px;margin:0 auto;">
        <h2 class="section-title">Send Us a Message</h2>
        <p style="text-align:center;color:var(--text-secondary);margin-bottom:2rem;">
          Have a question? We'd love to hear from you. Fill out the form and we'll get back to you soon.
        </p>
        <form action="#" method="POST" style="background:var(--white);padding:2rem;border-radius:var(--radius);">
          <div class="form-group">
            <label for="contact-name">Your Name *</label>
            <input type="text" id="contact-name" name="name" required />
          </div>
          <div class="form-group">
            <label for="contact-email">Email Address *</label>
            <input type="email" id="contact-email" name="email" required />
          </div>
          <div class="form-group">
            <label for="contact-message">Message *</label>
            <textarea id="contact-message" name="message" rows="5" required></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%;font-size:1.05rem;padding:0.9rem;">Send Message</button>
        </form>
      </div>
    </div>
  </section>
</Layout>
