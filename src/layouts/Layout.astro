---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Lily House Montessori Schools',
  description = 'Montessori Schools in Cape Town — Claremont, Durbanville, Melkbos',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/assets/favicon.png" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    :root {
      --teal: #00729A;
      --teal-dark: #005a7a;
      --teal-light: #e8f4f8;
      --green: #009A4C;
      --green-light: #e6f7ee;
      --cream: #FFF8F0;
      --text: #1A1A2E;
      --text-light: #6B7280;
      --white: #FFFFFF;
      --radius: 1rem;
      --shadow: 0 4px 12px rgba(0,0,0,0.06);
      --shadow-lg: 0 12px 32px rgba(0,0,0,0.1);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Raleway', sans-serif;
      color: var(--text);
      background: var(--white);
      line-height: 1.6;
      font-size: 1rem;
    }

    img { max-width: 100%; height: auto; display: block; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

    /* === HEADER === */
    .header {
      position: sticky; top: 0; z-index: 100;
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(10px);
      border-bottom: 2px solid var(--teal);
    }
    .header-inner {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0.75rem 1.5rem; max-width: 1400px; margin: 0 auto; gap: 1rem;
    }
    .header-logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; flex-shrink: 0; }
    .header-logo img { width: 44px; height: auto; }
    .header-logo span { font-weight: 800; font-size: 1.15rem; color: var(--teal); }

    .nav { display: flex; align-items: center; gap: 0.25rem; }
    .nav a {
      font-weight: 600; font-size: 0.9rem; color: var(--text);
      padding: 0.5rem 0.85rem; border-radius: 0.5rem;
      transition: background 0.2s, color 0.2s; text-decoration: none;
    }
    .nav a:hover { background: var(--teal-light); color: var(--teal); }

    .nav .dropdown { position: relative; }
    .nav .dropdown-menu {
      display: none; position: absolute; top: 100%; left: 0;
      background: var(--white); box-shadow: var(--shadow-lg);
      border-radius: var(--radius); padding: 0.5rem 0; min-width: 180px;
      border: 1px solid #e5e7eb; margin-top: 0.25rem;
    }
    .nav .dropdown:hover .dropdown-menu,
    .nav .dropdown:focus-within .dropdown-menu { display: block; }
    .nav .dropdown-menu a {
      display: block; padding: 0.6rem 1rem; font-size: 0.85rem; border-radius: 0;
    }

    .header-actions { display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0; }

    .btn {
      display: inline-block; font-family: 'Raleway', sans-serif;
      font-weight: 700; font-size: 0.9rem;
      padding: 0.6rem 1.4rem; border-radius: 2rem;
      border: none; cursor: pointer; text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .btn:hover { transform: translateY(-2px); box-shadow: 0 6px 16px rgba(0,0,0,0.15); }
    .btn-teal { background: var(--teal); color: var(--white); }
    .btn-green { background: var(--green); color: var(--white); }
    .btn-outline-white {
      background: transparent; color: var(--white);
      border: 2px solid rgba(255,255,255,0.6);
    }
    .btn-outline-white:hover { background: var(--white); color: var(--teal); border-color: var(--white); }

    /* === HERO === */
    .hero {
      position: relative; min-height: max(70vh, 500px);
      display: flex; align-items: center; justify-content: center;
      text-align: center; color: var(--white); overflow: hidden;
    }
    .hero-bg {
      position: absolute; inset: 0; width: 100%; height: 100%;
      object-fit: cover; z-index: 0;
    }
    .hero-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.2) 100%);
      z-index: 1;
    }
    .hero-content { position: relative; z-index: 2; max-width: 750px; padding: 2rem; }
    .hero-badge {
      display: inline-block; font-size: 0.8rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.12em;
      background: rgba(255,255,255,0.2); backdrop-filter: blur(4px);
      padding: 0.4rem 1.2rem; border-radius: 2rem; margin-bottom: 1rem;
    }
    .hero h1 { font-size: 3.2rem; color: var(--white); margin-bottom: 1rem; line-height: 1.15; }
    .hero p { font-size: 1.15rem; margin-bottom: 2rem; opacity: 0.9; }
    .hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

    /* === SECTIONS === */
    .section { padding: 5rem 0; }
    .section-title { font-size: 2.2rem; text-align: center; margin-bottom: 3rem; color: var(--text); font-weight: 800; }
    .section-teal { background: var(--teal-light); }
    .section-cream { background: var(--cream); }
    .section-green { background: var(--green-light); }

    .section-tag {
      display: inline-block; font-size: 0.8rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.12em;
      color: var(--teal); margin-bottom: 0.5rem;
    }
    .section-tag::before {
      content: ''; display: block; width: 28px; height: 3px;
      background: var(--teal); border-radius: 2px; margin-bottom: 0.75rem;
    }
    .section-header { text-align: center; max-width: 600px; margin: 0 auto 3rem; }
    .section-header .section-tag::before { margin: 0 auto 0.75rem; }

    /* === CARDS === */
    .card {
      background: var(--white); border-radius: var(--radius);
      padding: 1.5rem; box-shadow: var(--shadow);
      transition: transform 0.3s, box-shadow 0.3s;
    }
    .card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }

    /* === GRID === */
    .grid-3 { display: grid; grid-template-columns: 1fr; gap: 2rem; }
    @media (min-width: 768px) { .grid-3 { grid-template-columns: repeat(3, 1fr); } }
    .grid-2 { display: grid; grid-template-columns: 1fr; gap: 2rem; }
    @media (min-width: 768px) { .grid-2 { grid-template-columns: repeat(2, 1fr); } }

    /* === FOOTER === */
    .footer {
      background: var(--text); color: rgba(255,255,255,0.8);
      padding: 4rem 0 1.5rem; margin-top: 4rem;
    }
    .footer-grid {
      display: grid; grid-template-columns: 1fr; gap: 2rem;
      max-width: 1200px; margin: 0 auto; padding: 0 1.5rem;
    }
    @media (min-width: 768px) { .footer-grid { grid-template-columns: repeat(3, 1fr); } }
    .footer h3 { color: var(--white); font-size: 0.9rem; margin-bottom: 1rem; letter-spacing: 0.05em; }
    .footer p, .footer a { font-size: 0.85rem; line-height: 1.7; color: rgba(255,255,255,0.7); text-decoration: none; }
    .footer a:hover { color: var(--white); }
    .footer-links { list-style: none; }
    .footer-links li { margin-bottom: 0.5rem; }

    /* === BLOG CARD === */
    .blog-card {
      background: var(--white); border-radius: var(--radius);
      box-shadow: var(--shadow); overflow: hidden;
      transition: transform 0.3s, box-shadow 0.3s;
    }
    .blog-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
    .blog-card img { width: 100%; height: 200px; object-fit: cover; }
    .blog-card-body { padding: 1.5rem; }
    .blog-card-body time { font-size: 0.85rem; color: var(--text-light); }
    .blog-card-body h3 { font-size: 1.15rem; margin: 0.5rem 0; }
    .blog-card-body p { color: var(--text-light); font-size: 0.9rem; }
    .read-more { display: inline-block; margin-top: 0.75rem; font-weight: 600; color: var(--teal); text-decoration: none; }

    /* === FORM === */
    .form-group { margin-bottom: 1.25rem; }
    .form-group label { display: block; font-weight: 600; margin-bottom: 0.4rem; font-size: 0.9rem; }
    .form-group input, .form-group select, .form-group textarea {
      width: 100%; padding: 0.75rem 1rem;
      border: 2px solid #e5e7eb; border-radius: 0.75rem;
      font-family: 'Raleway', sans-serif; font-size: 0.95rem;
      transition: border-color 0.2s;
    }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
      outline: none; border-color: var(--teal);
    }

    /* === CTA BANNER === */
    .cta-banner {
      background: linear-gradient(135deg, var(--teal) 0%, var(--teal-dark) 100%);
      color: var(--white); text-align: center;
      padding: 4rem 2rem; border-radius: var(--radius);
      position: relative; overflow: hidden;
    }
    .cta-banner::before {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(circle at 20% 50%, rgba(255,255,255,0.1) 0%, transparent 50%);
    }
    .cta-banner h2 { color: var(--white); font-size: 2rem; margin-bottom: 1rem; position: relative; }
    .cta-banner p { font-size: 1.05rem; margin-bottom: 2rem; opacity: 0.9; position: relative; }
    .cta-banner .btn { position: relative; }

    /* === MISC === */
    .text-center { text-align: center; }
    .mt-2 { margin-top: 2rem; }

    /* === MOBILE === */
    .nav-toggle { display: none; background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--teal); }

    @media (max-width: 900px) {
      .header-inner { flex-wrap: wrap; padding: 0.5rem 1rem; }
      .nav-toggle { display: block; }
      .nav {
        display: none; flex-direction: column; position: absolute; top: 100%;
        left: 0; right: 0; background: var(--white);
        box-shadow: var(--shadow-lg); padding: 1rem; z-index: 200;
        border-bottom: 2px solid var(--teal);
      }
      .nav.open { display: flex; }
      .nav a { font-size: 1rem; padding: 0.75rem 1rem; min-height: 44px; display: flex; align-items: center; }
      .nav .dropdown-menu { position: static; box-shadow: none; padding-left: 1rem; display: none; border: none; }
      .nav .dropdown.open .dropdown-menu { display: block; }

      .hero { min-height: 500px !important; }
      .hero h1 { font-size: 2rem !important; }
      .hero p { font-size: 1rem !important; }
      .hero-actions { flex-direction: column; align-items: center; }
      .hero-actions .btn { width: 100%; max-width: 280px; }
      .section-title { font-size: 1.6rem !important; }
      .section { padding: 3rem 0 !important; }
      .container { padding: 0 1.25rem !important; }
      .cta-banner { padding: 2.5rem 1.5rem !important; }
      .cta-banner h2 { font-size: 1.4rem !important; }
      input, select, textarea { font-size: 16px !important; }
    }
  </style>
</head>
<body>
  <header class="header">
    <div class="header-inner">
      <a href="/" class="header-logo">
        <img src="/assets/lilyhouse-logo.png" alt="Lily House" width="44" height="32" />
        <span>Lily House</span>
      </a>
      <button class="nav-toggle" id="navToggle" aria-label="Menu">☰</button>
      <nav class="nav" id="mainNav">
        <a href="/">Home</a>
        <a href="/about">About Us</a>
        <div class="dropdown">
          <a href="/#campuses">Campuses ▾</a>
          <div class="dropdown-menu">
            <a href="/contact#claremont">Claremont</a>
            <a href="/contact#durbanville">Durbanville</a>
            <a href="/contact#melkbos">Melkbos</a>
          </div>
        </div>
        <a href="/admissions">Admissions</a>
        <a href="/blog">Blog</a>
        <a href="/contact">Contact</a>
      </nav>
      <div class="header-actions">
        <a href="/contact" class="btn btn-green">Book a Tour</a>
        <a href="/admissions" class="btn btn-teal">Enroll Now</a>
      </div>
    </div>
  </header>

  <main><slot /></main>

  <footer class="footer">
    <div class="footer-grid">
      <div>
        <h3>📍 Our Campuses</h3>
        <p><strong>Claremont</strong><br />80 Queen Victoria Road<br />qaanita@lilyhouseschool.co.za</p>
        <br />
        <p><strong>Durbanville</strong><br />16 Hooggelegen Road<br />tasneem@lilyhouseschool.co.za</p>
        <br />
        <p><strong>Melkbos</strong><br />42 Charles Hoffe Avenue<br />jess@lilyhouseschool.co.za</p>
      </div>
      <div>
        <h3>🔗 Quick Links</h3>
        <ul class="footer-links">
          <li><a href="/">Home</a></li>
          <li><a href="/about">About Us</a></li>
          <li><a href="/admissions">Admissions</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/contact">Contact</a></li>
          <li><a href="/admissions">Enroll Now</a></li>
          <li><a href="/contact">Book a Tour</a></li>
        </ul>
      </div>
      <div>
        <h3>📱 Connect With Us</h3>
        <p>Claremont: <a href="https://facebook.com">Facebook</a> · <a href="https://instagram.com">Instagram</a></p>
        <p>Durbanville: <a href="https://facebook.com">Facebook</a> · <a href="https://instagram.com">Instagram</a></p>
        <p>Melkbos: <a href="https://facebook.com">Facebook</a> · <a href="https://instagram.com">Instagram</a></p>
        <p style="margin-top:2rem;font-size:0.8rem;">&copy; 2026 Lily House Montessori Schools</p>
      </div>
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('navToggle');
    const nav = document.getElementById('mainNav');
    if (toggle && nav) {
      toggle.addEventListener('click', () => nav.classList.toggle('open'));
      nav.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => { if (window.innerWidth <= 900) nav.classList.remove('open'); });
      });
    }
  </script>
</body>
</html>
