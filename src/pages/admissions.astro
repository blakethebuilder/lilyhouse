---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Admissions — Lily House Montessori Schools">
  <section class="page-hero">
    <div class="container">
      <h1>Admissions</h1>
      <p class="subtitle">Start Your Child's Journey at Lily House</p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:700px;text-align:center;">
      <p style="font-size:1.1rem;color:var(--text-light);line-height:1.7;">We are so glad you're here. We've made our admissions process simple and straightforward. Find all the information you need to enroll your child below.</p>
    </div>
  </section>

  <section class="section section-alt" style="padding-top:0;">
    <div class="container">
      <h2 class="section-title">Our Enrolment Process</h2>
      <div class="grid-3">
        <div class="step"><div class="step-number">1</div><h3>Book a Tour</h3><p style="color:var(--text-light);">Visit a campus and meet our team in person.</p></div>
        <div class="step"><div class="step-number">2</div><h3>Apply Online</h3><p style="color:var(--text-light);">Complete the enrollment form below to begin the process.</p></div>
        <div class="step"><div class="step-number">3</div><h3>Welcome to Lily House</h3><p style="color:var(--text-light);">We'll contact you to confirm enrollment and welcome your family.</p></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">Pricing &amp; Fees</h2>
      <p class="text-center" style="color:var(--text-light);margin-bottom:2rem;">Clear, all-inclusive fee structures.</p>

      <h3 style="font-size:1.4rem;margin-bottom:1rem;color:var(--teal);">Claremont Fees 2026</h3>
      <div style="overflow-x:auto;margin-bottom:3rem;">
        <table class="fee-table">
          <thead><tr><th>Programme</th><th>Fee</th></tr></thead>
          <tbody>
            <tr><td>Toddler (18-36mo) — Half Day (07:30-12:30)</td><td class="fee-amount">R4,190<span style="font-weight:400;color:var(--text-light);"> /mo</span></td></tr>
            <tr><td>Toddler (18-36mo) — Full Day (07:30-17:00)</td><td class="fee-amount">R5,270<span style="font-weight:400;color:var(--text-light);"> /mo</span></td></tr>
            <tr><td colspan="2" style="font-size:0.85rem;color:var(--text-light);"><strong>Annual Resource Fee:</strong> R1,500</td></tr>
          </tbody>
        </table>
      </div>

      <h4 style="margin-bottom:0.5rem;">Optional Extras</h4>
      <div style="overflow-x:auto;margin-bottom:3rem;">
        <table class="fee-table">
          <thead><tr><th>Extra</th><th>Cost</th></tr></thead>
          <tbody>
            <tr><td>Aftercare (daily)</td><td class="fee-amount">R90<span style="font-weight:400;color:var(--text-light);"> /day</span></td></tr>
            <tr><td>Lunch (monthly)</td><td class="fee-amount">R550<span style="font-weight:400;color:var(--text-light);"> /mo</span></td></tr>
            <tr><td>Holiday Club — Half Day</td><td class="fee-amount">R170<span style="font-weight:400;color:var(--text-light);"> /day</span></td></tr>
            <tr><td>Holiday Club — Full Day</td><td class="fee-amount">R240<span style="font-weight:400;color:var(--text-light);"> /day</span></td></tr>
          </tbody>
        </table>
      </div>

      <h3 style="font-size:1.4rem;margin-bottom:1rem;color:var(--teal);">Durbanville &amp; Melkbos</h3>
      <p style="color:var(--text-light);margin-bottom:1rem;">Contact each campus directly for the latest fee schedule.</p>
      <a href="/contact" class="btn btn-teal">View Campuses</a>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container" style="max-width:700px;">
      <h2 class="section-title">Enroll Now</h2>
      <p class="text-center" style="color:var(--text-light);margin-bottom:2rem;">Complete the form to begin. We'll contact you within 2 business days.</p>
      <form class="enroll-form" action="mailto:blake@smartintegrate.co.za" method="GET" enctype="text/plain">
        <input type="text" name="parent-name" placeholder="Parent's Full Name *" required />
        <input type="text" name="child-name" placeholder="Child's Full Name *" required />
        <input type="email" name="email" placeholder="Parent's Email *" required />
        <input type="tel" name="phone" placeholder="Parent's Number *" required />
        <input type="date" name="dob" required />
        <select name="campus" required>
          <option value="">Choose Your Campus *</option>
          <option value="claremont">Claremont</option>
          <option value="durbanville">Durbanville</option>
          <option value="melkbos">Melkbos</option>
        </select>
        <input type="date" name="start-date" placeholder="Preferred Start Date" />
        <textarea name="questions" rows="3" placeholder="Questions or Comments?"></textarea>
        <button type="submit" class="btn btn-green" style="width:100%;padding:0.9rem;font-size:1.05rem;">Send</button>
      </form>
    </div>
  </section>
</Layout>

<style>
  .enroll-form { background:var(--white); padding:2rem; border-radius:var(--radius); }
  .enroll-form input, .enroll-form select, .enroll-form textarea {
    width:100%; padding:0.75rem 1rem; margin-bottom:1rem;
    border:2px solid #e5e7eb; border-radius:0.75rem;
    font-family:'Raleway',sans-serif; font-size:0.95rem;
  }
  .enroll-form input:focus, .enroll-form select:focus, .enroll-form textarea:focus {
    outline:none; border-color:var(--teal);
  }
</style>
