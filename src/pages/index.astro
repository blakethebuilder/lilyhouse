---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lily House Montessori Schools — Cape Town" description="Independent Montessori preschool and primary school across three Cape Town campuses — Claremont, Durbanville, and Melkbos.">
  <section class="hero">
    <img class="hero-bg-img" src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Evie-Toua-6-9-Educator.jpg?fit=1200%2C800&ssl=1" alt="" loading="eager" />
    <div class="hero-overlay"></div>
    <div class="container">
      <div class="hero-content">
        <h1>Lily House Montessori<br />Schools in Cape Town</h1>
        <p class="subtitle">We offer independent Montessori preschool and primary education across three unique campuses in Claremont, Durbanville, and Melkbos.</p>
        <a href="/contact" class="btn btn-green">Contact Us</a>
      </div>
    </div>
  </section>

  <section class="section" id="campuses">
    <div class="container">
      <h2 class="section-title">Find Your Campus</h2>
      <div class="campus-grid">
        <a href="/campuses/claremont" class="campus-card-link fade-in">
          <img src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Jaxon_B_Candid-1.jpg?fit=800%2C534&ssl=1" alt="Claremont classroom" loading="lazy" />
          <div class="campus-card-body">
            <h3>Lily House Claremont</h3>
            <p>Small class sizes and personalised attention in the heart of the leafy Southern Suburbs.</p>
          </div>
        </a>
        <a href="/campuses/durbanville" class="campus-card-link fade-in">
          <img src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/02/Lily-House-52-scaled.jpg?fit=800%2C534&ssl=1" alt="Durbanville classroom" loading="lazy" />
          <div class="campus-card-body">
            <h3>Lily House Durbanville</h3>
            <p>Our Durbanville campus offers a unique learning experience, where education blossoms amidst the rolling vineyards and orchards of the valley.</p>
          </div>
        </a>
        <a href="/campuses/melkbos" class="campus-card-link fade-in">
          <img src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Lily-House-14.jpg?fit=800%2C534&ssl=1" alt="Melkbos classroom" loading="lazy" />
          <div class="campus-card-body">
            <h3>Lily House Melkbos</h3>
            <p>A nurturing, intimate school environment where coastal charm meets Montessori excellence on the West Coast.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">A Foundation for Lifelong Learning</h2>
      <p class="text-center" style="color:var(--text-light);margin-bottom:2rem;max-width:800px;margin-left:auto;margin-right:auto;line-height:1.7;">At Lily House, we are dedicated to providing a solid foundation for your child's education. Our Montessori curriculum nurtures curiosity, builds independence, and empowers children to become confident, capable learners. We prepare them for their next educational step and beyond.</p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Nurturing Young Minds</h2>
      <p class="text-center" style="color:var(--text-light);margin-bottom:2.5rem;max-width:700px;margin-left:auto;margin-right:auto;">Our approach celebrates each child's innate desire to learn through hands-on exploration and self-directed activities.</p>
      <div class="philosophy-grid">
        <div class="pillar-card fade-in">
          <h3 style="color:var(--teal);margin-bottom:0.5rem;">Hands-On Learning</h3>
          <p style="color:var(--text-light);">Children engage with specially designed Montessori materials, fostering deep understanding and cognitive growth.</p>
        </div>
        <div class="pillar-card fade-in">
          <h3 style="color:var(--teal);margin-bottom:0.5rem;">Individualised Progress</h3>
          <p style="color:var(--text-light);">We tailor our teaching to each child's unique pace and learning style, ensuring they thrive at every stage of development.</p>
        </div>
        <div class="pillar-card fade-in">
          <h3 style="color:var(--teal);margin-bottom:0.5rem;">Practical Life Skills</h3>
          <p style="color:var(--text-light);">Children develop essential skills like concentration, coordination, and orderliness, building a strong foundation for future success.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">Academic Excellence</h2>
      <p class="text-center" style="color:var(--text-light);margin-bottom:2rem;max-width:800px;margin-left:auto;margin-right:auto;line-height:1.7;">We seamlessly integrate Montessori principles with standard academic requirements. Whether in our Preschool or Primary phase, we emphasise language development and foundational numeracy skills. Our curriculum broadens children's understanding of the world through history, geography, and culture, ensuring they are fully prepared for any academic path they choose.</p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">From the Lily House Community</h2>
      <p class="text-center" style="color:var(--text-light);margin-bottom:2rem;">Follow each campus on Instagram for daily updates, stories, and Montessori moments.</p>
      <div class="campus-grid">
        <a href="https://www.instagram.com/lilyhouseclaremont/" target="_blank" rel="noopener" class="campus-card-link fade-in">
          <img src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/02/Lily-House-123-scaled.jpg?fit=800%2C534&ssl=1" alt="Claremont" loading="lazy" />
          <div class="campus-card-body">
            <h3>@lilyhouseclaremont</h3>
