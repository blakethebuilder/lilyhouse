---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Why Lily House Is the Leading Montessori School in Durbanville — Lily House">
  <section class="page-hero">
    <div class="container">
      <p class="breadcrumb"><a href="/blog" style="color:rgba(255,255,255,0.7);">← Back to Blog</a></p>
      <h1>Why Lily House Is the Leading Montessori School in Durbanville</h1>
      <p class="subtitle">April 13, 2026</p>
    </div>
  </section>
  <section class="section">
    <div class="container" style="max-width:720px;">
      <img src="https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=1200&q=80" alt="Durbanville campus" style="width:100%;border-radius:1rem;margin-bottom:2rem;" />
      <p>Set against the rolling vineyards and orchards of the Durbanville valley, Lily House Durbanville offers a truly unique educational experience.</p>
      <h2 style="color:var(--teal);margin:1.5rem 0 1rem;">Education That Blossoms in Nature</h2>
      <ul style="color:var(--text-light);line-height:1.8;">
        <li><strong>Farm-based learning environment</strong> — children connect with nature daily</li>
        <li><strong>Mixed-age classrooms</strong> — peer learning builds leadership skills</li>
        <li><strong>Montessori-certified guides</strong> — dedicated educators</li>
        <li><strong>Comprehensive programmes</strong> — toddler through primary years</li>
      </ul>
      <div style="text-align:center;margin-top:2rem;">
        <a href="/contact" class="btn btn-teal">Book a Tour</a>
      </div>
    </div>
  </section>
</Layout>
