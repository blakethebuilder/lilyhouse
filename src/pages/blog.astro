---
import Layout from '../layouts/Layout.astro';
const posts = [
  { title:'Montessori School Melkbos: What Makes Lily House Unique on the West Coast', date:'April 28, 2026', excerpt:'Comparing schools in Melkbosstrand? Read about our private Montessori school in Melkbos.', image:'https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Jess-Hanafey-Principal-6-9-Educator-Creative-Communications-Lead.jpg?fit=300%2C200&ssl=1', slug:'montessori-melkbos-unique' },
  { title:'Why Lily House Is the Leading Montessori School in Durbanville', date:'April 13, 2026', excerpt:'A look inside our farm-based Montessori campus in Durbanville.', image:'https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/02/Lily-House-104-scaled.jpg?fit=300%2C200&ssl=1', slug:'leading-montessori-durbanville' },
];
---
<Layout title="Blog — Lily House Montessori Schools">
  <section class="page-hero">
    <div class="container">
      <h1>From the Lily House Community</h1>
      <p class="subtitle">Stories, updates, and Montessori insights from our classrooms to your home.</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="blog-grid">
        {posts.map(p => (
          <article class="blog-card">
            <img src={p.image} alt={p.title} loading="lazy" />
            <div class="blog-card-body">
              <time>{p.date}</time>
              <h3><a href={`/blog/${p.slug}`}>{p.title}</a></h3>
              <p>{p.excerpt}</p>
              <a href={`/blog/${p.slug}`} class="read-more">Read More »</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
<style>
  .blog-grid { display:grid; grid-template-columns:1fr; gap:2rem; }
  @media (min-width:768px) { .blog-grid { grid-template-columns:repeat(2,1fr); } }
</style>
