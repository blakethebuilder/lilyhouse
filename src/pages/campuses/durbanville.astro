---
import Layout from '../../layouts/Layout.astro';
const team = [
  { name:'Tasneem Khan', role:'Campus lead and toddler guide', img:'https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Durbanville-Campus-Lead-Toddler-Directress_Tasneem-Khan.jpg?fit=400%2C534&ssl=1' },
  { name:'Lettie Mogapi', role:'Toddler assistant', img:'https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Durbanville-Toddler-Assistant-Lettie-Mogapi.jpg?fit=400%2C534&ssl=1' },
  { name:'Patience Mbidzo', role:'Toddler Assistant', img:'https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Durbanville-Toddler-Assistant_Patience-Mbidzo.jpg?fit=400%2C534&ssl=1' },
  { name:'Poppy Morabe', role:'Preschool assistant', img:'https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Durbanville-Preschool-Assistant_Poppy-Morabe-1.jpg?fit=400%2C534&ssl=1' },
];
const values = [
  { title:'Prepared Environments', desc:'Safe, stimulating, and nurturing spaces for learning.' },
  { title:'Complete Wellness', desc:'Supporting the physical, emotional, and social well-being of each child.' },
  { title:'Self & Creative Expression', desc:'Opportunities for art, music, movement, and imaginative play.' },
  { title:'Child-Centred Learning', desc:'A curriculum designed to meet the individual needs and interests of each child.' },
];
---

<Layout title="Durbanville Campus — Lily House Montessori Schools">
  <section class="hero">
    <img class="hero-bg-img" src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/02/Lily-House-104-scaled.jpg?fit=1200%2C800&ssl=1" alt="" loading="eager" />
    <div class="hero-overlay"></div>
    <div class="container">
      <div class="hero-content">
        <h1>Lily House Durbanville:<br />Where Nature Inspires Learning</h1>
        <p class="subtitle">Welcome to our unique learning environment nestled in the Durbanville valley. Here, education blossoms amidst rolling vineyards and orchards, using the natural world to spark curiosity and deepen the learning experience.</p>
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
          <a href="/admissions" class="btn btn-green">Enroll Now</a>
          <a href="/contact" class="btn btn-teal">Book a Tour</a>
          <a href="https://wa.me/27745497336" class="btn btn-green" target="_blank" rel="noopener">WhatsApp</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Why Choose Our Durbanville Campus?</h2>
      <div class="grid-3">
        <div class="pillar-card"><h3 style="color:var(--teal);margin-bottom:0.5rem;">Unparalleled Natural Setting</h3><p style="color:var(--text-light);">Our classrooms extend beyond the walls and into the farm. Children learn and play amidst the beauty of a working farm, fostering a deep connection with nature and each other.</p></div>
        <div class="pillar-card"><h3 style="color:var(--teal);margin-bottom:0.5rem;">Outdoor Exploration</h3><p style="color:var(--text-light);">Our curriculum seamlessly integrates outdoor learning. Children engage in hands-on discovery, exploring the vineyards, orchards, and gardens, which stimulates curiosity and a love for the natural world.</p></div>
        <div class="pillar-card"><h3 style="color:var(--teal);margin-bottom:0.5rem;">Sensory-Rich Environment</h3><p style="color:var(--text-light);">The sights, sounds, and smells of the farm stimulate all the senses. This unique setting enriches the learning process and creates a tranquil, supportive environment for growth.</p></div>
      </div>
      <div class="values-grid" style="margin-top:2rem;">
        {values.map(v => (<div class="value-card"><h3>{v.title}</h3><p>{v.desc}</p></div>))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="lead-block">
        <img src="https://i0.wp.com/lilyhouseschool.co.za/wp-content/uploads/2025/11/Durbanville-Campus-Lead-Toddler-Directress_Tasneem-Khan.jpg?fit=800%2C534&ssl=1" alt="Tasneem Khan" loading="lazy" />
        <div class="lead-info">
          <h2>Meet Our Campus Lead</h2>
          <p><strong>Name:</strong> Tasneem Khan</p>
          <p><strong>Email:</strong> <a href="mailto:tasneem@lilyhouseschool.co.za">tasneem@lilyhouseschool.co.za</a></p>
          <a href="/admissions" class="btn btn-green" style="margin-top:1rem;">Enroll Now</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">Meet the Durbanville Team</h2>
      <p class="text-center" style="color:var(--text-light);margin-bottom:2rem;">Our team of passionate educators uses the surrounding vineyards and orchards as an extension of the classroom to spark curiosity and a love for nature.</p>
      <div class="team-grid">
        {team.map(m => (
          <div class="team-card">
            {m.img ? <img src={m.img} alt={m.name} loading="lazy" /> : <div class="team-placeholder">{m.name.split(' ').map(n => n[0]).join('')}</div>}
            <div class="team-body"><h3>{m.name}</h3><p>{m.role}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt text-center">
    <h2 style="font-size:1.8rem;margin-bottom:0.5rem;">Tour Our Durbanville Campus</h2>
    <p style="color:var(--text-light);margin-bottom:1.5rem;">Come and explore our one-of-a-kind learning environment. We'd love to show you around.</p>
    <a href="/contact" class="btn btn-teal" style="font-size:1.05rem;">Book a Tour</a>
  </section>
</Layout>
<style>
  .values-grid { display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; }
  @media (min-width:768px) { .values-grid { grid-template-columns:repeat(4,1fr); } }
  .value-card { background:var(--teal-light); border-radius:var(--radius); padding:1.5rem; text-align:center; }
  .value-card h3 { font-size:1rem; color:var(--teal); margin-bottom:0.5rem; font-weight:700; }
  .value-card p { font-size:0.85rem; color:var(--text-light); }
  .lead-block { display:grid; grid-template-columns:1fr; gap:2rem; align-items:center; }
  @media (min-width:768px) { .lead-block { grid-template-columns:1fr 1fr; } }
  .lead-block img { width:100%; border-radius:var(--radius); }
  .lead-info h2 { font-size:1.6rem; color:var(--teal); margin-bottom:1rem; }
  .lead-info p { margin-bottom:0.5rem; color:var(--text-light); }
  .lead-info a { color:var(--teal); }
  .team-grid { display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; }
  @media (min-width:768px) { .team-grid { grid-template-columns:repeat(3,1fr); } }
  .team-card { background:var(--white); border-radius:var(--radius); overflow:hidden; box-shadow:var(--shadow); transition:transform 0.3s ease, box-shadow 0.3s ease; }
  .team-card:hover { transform:translateY(-4px); box-shadow:var(--shadow-lg); }
  .team-card img { width:100%; height:260px; object-fit:cover; }
  .team-placeholder { width:100%; height:200px; background:var(--teal-light); display:flex; align-items:center; justify-content:center; font-size:2rem; font-weight:800; color:var(--teal); }
  .team-body { padding:1rem; }
  .team-body h3 { font-size:1rem; color:var(--teal); margin-bottom:0.25rem; }
  .team-body p { font-size:0.85rem; color:var(--text-light); }
</style>
